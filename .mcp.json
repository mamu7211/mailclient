{
  "mcpServers": {
    "aspire": {
      "command": "aspire",
      "args": [
        "agent",
        "mcp"
      ]
    },
    "postgres": {
      "command": "bash",
      "args": [
        ".claude/skills/dev-harness/postgres-mcp.sh"
      ]
    },
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "@playwright/mcp@0.0.70",
        "--ignore-https-errors"
      ],
      "env": {}
    }
  }
}