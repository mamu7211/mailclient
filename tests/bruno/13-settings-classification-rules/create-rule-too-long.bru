meta {
  name: Create Rule Instruction Too Long
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/api/settings/rules
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

script:pre-request {
  const longInstruction = "a".repeat(501);
  req.setBody({ instruction: longInstruction });
}

tests {
  test("should return 400", function() {
    expect(res.status).to.equal(400);
  });

  test("should return error message", function() {
    expect(res.body.message).to.be.a("string");
  });
}
