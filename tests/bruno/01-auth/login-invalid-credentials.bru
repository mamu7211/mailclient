meta {
  name: Login - Invalid Credentials
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/api/auth/login
  body: json
  auth: none
}

body:json {
  {
    "username": "admin",
    "password": "wrong-password"
  }
}

tests {
  test("should return 401", function() {
    expect(res.status).to.equal(401);
  });
}
