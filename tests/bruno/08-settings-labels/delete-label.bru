meta {
  name: Delete Label
  type: http
  seq: 4
}

delete {
  url: {{baseUrl}}/api/settings/labels/{{testLabelId}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

tests {
  test("should return 200", function() {
    expect(res.status).to.equal(200);
  });

  test("should return confirmation message", function() {
    expect(res.body.message).to.be.a("string");
  });
}
