meta {
  name: Test SMTP Connection
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/setup/test-smtp
  body: json
  auth: none
}

body:json {
  {
    "host": "{{greenmailHost}}",
    "port": 3025,
    "tlsMode": "None",
    "requiresAuth": false
  }
}

tests {
  test("should return 200", function() {
    expect(res.status).to.equal(200);
  });

  test("should return success", function() {
    expect(res.body.success).to.equal(true);
  });
}
