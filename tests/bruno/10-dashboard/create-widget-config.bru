meta {
  name: Create Widget Config
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/dashboard/widgets/bruno-test-widget/config
  body: json
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

body:json {
  {
    "configValue": "{\"color\":\"blue\",\"refreshInterval\":30}"
  }
}

tests {
  test("should return 201", function() {
    expect(res.status).to.equal(201);
  });

  test("should return config value", function() {
    expect(res.body.configValue).to.contain("blue");
  });
}
