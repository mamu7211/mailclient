# Bruno CLI test runner
# Build context: repository root (..)

FROM docker.io/library/node:22-alpine

RUN apk add --no-cache curl
RUN npm install -g @usebruno/cli

WORKDIR /app
COPY tests/bruno/ .

COPY tests/wait-for-api.sh /usr/local/bin/wait-for-api
RUN chmod +x /usr/local/bin/wait-for-api

ENTRYPOINT ["sh", "-c", "wait-for-api && bru run --env docker"]
