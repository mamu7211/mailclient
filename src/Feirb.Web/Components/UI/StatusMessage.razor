@namespace Feirb.Web.Components.UI

@* Centered status message with icon, heading, description, and optional action button. *@
<div class="text-center py-5">
    <Icon Name="@Icon" Class="display-1 text-muted mb-3 d-block" />
    @if (IsFullPage)
    {
        <h1 class="fw-bold">@Title</h1>
    }
    else
    {
        <h2 class="fw-bold">@Title</h2>
    }
    <p class="text-muted mb-4">@Message</p>
    @if (!string.IsNullOrEmpty(ButtonText) && !string.IsNullOrEmpty(ButtonHref))
    {
        <a href="@ButtonHref" class="btn btn-primary">@ButtonText</a>
    }
</div>

@code {
    /// <summary>Bootstrap Icon name without the bi- prefix.</summary>
    [Parameter, EditorRequired]
    public string Icon { get; set; } = "";

    /// <summary>Heading text.</summary>
    [Parameter, EditorRequired]
    public string Title { get; set; } = "";

    /// <summary>Descriptive message below the heading.</summary>
    [Parameter, EditorRequired]
    public string Message { get; set; } = "";

    /// <summary>Optional button label.</summary>
    [Parameter]
    public string? ButtonText { get; set; }

    /// <summary>Optional button navigation target.</summary>
    [Parameter]
    public string? ButtonHref { get; set; }

    /// <summary>When true, renders heading as h1 (for full-page error display). Defaults to false (h2).</summary>
    [Parameter]
    public bool IsFullPage { get; set; }
}
