@namespace Feirb.Web.Components.UI

@* Switch toggle with label that appears strikethrough when deactivated. *@
<div class="form-check form-switch mb-0 @Class">
    <input type="checkbox" id="@_id" class="form-check-input"
           @bind="Value" @bind:after="OnToggleAsync"
           @attributes="AdditionalAttributes" />
    <label for="@_id" class="form-check-label @(Value ? "" : "text-decoration-line-through text-muted")">
        @Text
    </label>
</div>

@code {
    /// <summary>Current toggle state.</summary>
    [Parameter]
    public bool Value { get; set; }

    /// <summary>Fires when the toggle state changes.</summary>
    [Parameter]
    public EventCallback<bool> ValueChanged { get; set; }

    /// <summary>Label text displayed next to the toggle.</summary>
    [Parameter, EditorRequired]
    public string Text { get; set; } = default!;

    /// <summary>Additional CSS classes.</summary>
    [Parameter]
    public string? Class { get; set; }

    /// <summary>Any extra HTML attributes.</summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }

    private readonly string _id = $"toggle-{Guid.NewGuid():N}";

    private async Task OnToggleAsync() =>
        await ValueChanged.InvokeAsync(Value);
}
