@namespace Feirb.Web.Components.UI

@* Table row with optional click handler. *@
<tr class="@(OnClick.HasDelegate ? "feirb-table-row-clickable" : "") @Class"
    @onclick="OnClick"
    @attributes="AdditionalAttributes">
    @ChildContent
</tr>

@code {
    /// <summary>Row content (TableCell elements).</summary>
    [Parameter, EditorRequired]
    public RenderFragment ChildContent { get; set; } = null!;

    /// <summary>Click event on the row.</summary>
    [Parameter]
    public EventCallback<MouseEventArgs> OnClick { get; set; }

    /// <summary>Additional CSS classes.</summary>
    [Parameter]
    public string? Class { get; set; }

    /// <summary>Any extra HTML attributes.</summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
