@inject NotificationService NotificationService
@inject IJSRuntime Js
@implements IDisposable

<div class="toast-container" role="alert" aria-live="polite">
    @foreach (var notification in NotificationService.Notifications)
    {
        var id = notification.Id;
        var seconds = NotificationService.GetAutoDismissSeconds(notification.Severity);

        <div @key="id" class="toast-item toast-@GetSeverityClass(notification.Severity)">
            <div class="toast-indicator">
                @if (seconds is { } s)
                {
                    <div class="toast-indicator-fill"
                         data-toast-id="@id"
                         style="animation-duration: @(s)s;">
                    </div>
                }
                else
                {
                    <div class="toast-indicator-fill toast-indicator-static"></div>
                }
            </div>
            <div class="toast-content">
                <i class="bi bi-@GetIcon(notification.Severity) toast-icon"></i>
                <div class="toast-body">
                    @notification.Message
                </div>
                <button type="button"
                        class="btn-close btn-close-sm"
                        aria-label="Close"
                        @onclick="() => NotificationService.Dismiss(id)">
                </button>
            </div>
        </div>
    }
</div>

@code {
    private DotNetObjectReference<ToastContainer>? _dotNetRef;

    protected override void OnInitialized()
    {
        _dotNetRef = DotNetObjectReference.Create(this);
        NotificationService.OnChange += OnNotificationChange;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Js.InvokeVoidAsync("toastInterop.init", _dotNetRef);
        }
    }

    [JSInvokable]
    public void OnAnimationEnd(string toastId)
    {
        if (Guid.TryParse(toastId, out var id))
            NotificationService.Dismiss(id);
    }

    private void OnNotificationChange() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        NotificationService.OnChange -= OnNotificationChange;
        _dotNetRef?.Dispose();
    }

    private static string GetSeverityClass(NotificationSeverity severity) => severity switch
    {
        NotificationSeverity.Error => "danger",
        NotificationSeverity.Warning => "warning",
        NotificationSeverity.Success => "success",
        NotificationSeverity.Info => "info",
        _ => "info",
    };

    private static string GetIcon(NotificationSeverity severity) => severity switch
    {
        NotificationSeverity.Error => "exclamation-circle",
        NotificationSeverity.Warning => "exclamation-triangle",
        NotificationSeverity.Success => "check-circle",
        NotificationSeverity.Info => "info-circle",
        _ => "info-circle",
    };
}
