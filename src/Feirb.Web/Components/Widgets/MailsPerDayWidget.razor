@inject HttpClient Http
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResources> L
@implements IAsyncDisposable

<WidgetCard InstanceId="@InstanceId"
            EditMode="EditMode"
            OnRemove="OnRemove"
            OnConfigLoaded="OnConfigLoadedAsync"
            GetPendingConfig="GetPendingConfig">
    <Content>
        <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="text-muted small">@L["WidgetMailsPerDayName"]</span>
        </div>
        @if (_loading)
        {
            <div class="d-flex flex-grow-1 align-items-center justify-content-center">
                <div class="spinner-border spinner-border-sm" role="status"></div>
            </div>
        }
        else
        {
            <div class="flex-grow-1" style="position: relative; min-height: 0;">
                <canvas id="@_canvasId"></canvas>
            </div>
        }
    </Content>
    <ConfigDialog>
        <div class="mb-3">
            <label class="form-label">@L["WidgetMailsPerDaySettingsRange"]</label>
            <select class="form-select" value="@_pendingDays" @onchange="OnPendingDaysChanged">
                <option value="7">@L["ChartRange7Days"]</option>
                <option value="14">@L["ChartRange14Days"]</option>
                <option value="30">@L["ChartRange1Month"]</option>
                <option value="90">@L["ChartRange3Months"]</option>
                <option value="180">@L["ChartRange6Months"]</option>
                <option value="365">@L["ChartRange1Year"]</option>
            </select>
        </div>
    </ConfigDialog>
</WidgetCard>

@code {
    private readonly string _canvasId = $"chart-{Guid.NewGuid():N}";
    private bool _loading = true;
    private int _selectedDays = 7;
    private int _pendingDays = 7;

    [Parameter, EditorRequired] public string InstanceId { get; set; } = "";
    [Parameter] public bool EditMode { get; set; }
    [Parameter] public EventCallback OnRemove { get; set; }

    private async Task OnConfigLoadedAsync(string? config)
    {
        if (int.TryParse(config, out var days))
        {
            _selectedDays = days;
            _pendingDays = days;
        }

        await LoadChartAsync();
    }

    private void OnPendingDaysChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var days))
            _pendingDays = days;
    }

    private string? GetPendingConfig() => _pendingDays.ToString();

    private async Task LoadChartAsync()
    {
        try
        {
            var stats = await Http.GetFromJsonAsync<MailStatsResponse>($"/api/mail/stats?days={_selectedDays}");
            if (stats is not null)
            {
                _loading = false;
                StateHasChanged();
                await Task.Yield();

                var labels = stats.MailsPerDay.Select(d => d.Date.ToString("MM/dd")).ToArray();
                var data = stats.MailsPerDay.Select(d => d.Count).ToArray();
                await JS.InvokeVoidAsync("chartjsInterop.renderBarChart",
                    _canvasId, labels, data, L["WidgetMailsPerDayName"].Value);
            }
        }
        catch
        {
            _loading = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("chartjsInterop.destroyChart", _canvasId);
        }
        catch (JSDisconnectedException)
        {
            // Ignored during disposal
        }
    }
}
