@inject HttpClient Http
@inject IStringLocalizer<SharedResources> L

<WidgetCard InstanceId="@InstanceId">
    <Content>
        <div class="h-100 d-flex flex-column align-items-center justify-content-center">
            <span class="text-muted small">@L["WidgetMailCountName"]</span>
            @if (_loading)
            {
                <div class="spinner-border spinner-border-sm mt-2" role="status"></div>
            }
            else
            {
                <span class="display-3 fw-bold text-primary">@_totalCount</span>
            }
        </div>
    </Content>
</WidgetCard>

@code {
    private int _totalCount;
    private bool _loading = true;

    [Parameter, EditorRequired] public string InstanceId { get; set; } = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var stats = await Http.GetFromJsonAsync<MailStatsResponse>("/api/mail/stats");
            if (stats is not null)
                _totalCount = stats.TotalCount;
        }
        catch
        {
            _totalCount = 0;
        }
        finally
        {
            _loading = false;
        }
    }
}
