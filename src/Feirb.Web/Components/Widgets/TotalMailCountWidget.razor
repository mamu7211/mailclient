@inject HttpClient Http
@inject IStringLocalizer<SharedResources> L

<div class="widget-card h-100 d-flex flex-column align-items-center justify-content-center p-3">
    <span class="text-muted small">@L["WidgetMailCountName"]</span>
    @if (_loading)
    {
        <div class="spinner-border spinner-border-sm mt-2" role="status"></div>
    }
    else
    {
        <span class="display-3 fw-bold text-primary">@_totalCount</span>
    }
</div>

@code {
    private int _totalCount;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var stats = await Http.GetFromJsonAsync<MailStatsResponse>("/api/mail/stats");
            if (stats is not null)
                _totalCount = stats.TotalCount;
        }
        catch
        {
            _totalCount = 0;
        }
        finally
        {
            _loading = false;
        }
    }
}
