@inherits WidgetBase
@inject HttpClient Http
@inject IStringLocalizer<SharedResources> L

<WidgetCard InstanceId="@InstanceId" EditMode="EditMode" OnRemove="OnRemove">
    <Content>
        <div class="h-100 d-flex flex-column align-items-center justify-content-center">
            <span class="text-muted small">@L["WidgetMailCountName"]</span>
            <WidgetStateView State="State" ErrorMessage="ErrorMessage" OnRetry="RetryAsync">
                <span class="fw-bold text-primary" style="font-size: 6rem; line-height: 1;">@_totalCount</span>
            </WidgetStateView>
        </div>
    </Content>
</WidgetCard>

@code {
    private int _totalCount;

    protected override async Task OnInitializedAsync() =>
        await ExecuteLoadAsync();

    protected override async Task LoadDataAsync()
    {
        var stats = await Http.GetFromJsonAsync<MailStatsResponse>("/api/mail/stats");
        if (stats is not null)
        {
            _totalCount = stats.TotalCount;
            State = WidgetState.Ready;
        }
    }
}
