@inject HttpClient Http
@inject IStringLocalizer<SharedResources> L

<div class="widget-card h-100 d-flex flex-column p-3 position-relative">
    @if (EditMode)
    {
        <div class="widget-edit-controls">
            <button class="widget-corner-btn widget-settings-btn"
                    @onclick="OpenSettings"
                    @onclick:stopPropagation="true">
                <i class="bi bi-gear"></i>
            </button>
            <button class="widget-corner-btn widget-close-btn"
                    @onclick="OnRemove"
                    @onclick:stopPropagation="true">
                <i class="bi bi-x"></i>
            </button>
        </div>
    }
    @if (!string.IsNullOrEmpty(_configError))
    {
        <div class="alert alert-warning py-1 px-2 mb-2 small">
            <Icon Name="exclamation-triangle" Size="IconSize.Small" />
            @_configError
        </div>
    }
    @Content
</div>

@if (ConfigDialog is not null)
{
    <WidgetSettingsDialog Visible="_settingsVisible"
                          Title="@L["WidgetSettingsTitle"]"
                          OnSave="SaveSettingsAsync"
                          OnClose="CloseSettings">
        @ConfigDialog
    </WidgetSettingsDialog>
}

@code {
    private string? _config;
    private bool _settingsVisible;
    private string? _configError;

    [Parameter, EditorRequired] public string InstanceId { get; set; } = "";
    [Parameter, EditorRequired] public RenderFragment Content { get; set; } = null!;
    [Parameter] public bool EditMode { get; set; }
    [Parameter] public EventCallback OnRemove { get; set; }
    [Parameter] public RenderFragment? ConfigDialog { get; set; }
    [Parameter] public EventCallback<string?> OnConfigLoaded { get; set; }
    [Parameter] public Func<string?>? GetPendingConfig { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (ConfigDialog is null || string.IsNullOrEmpty(InstanceId)) return;

        try
        {
            var response = await Http.GetAsync($"/api/dashboard/widgets/{InstanceId}/config");
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<WidgetConfigResponse>();
                _config = result?.ConfigValue;
            }
            _configError = null;
        }
        catch
        {
            _configError = L["WidgetConfigLoadError"];
        }

        await OnConfigLoaded.InvokeAsync(_config);
    }

    private void OpenSettings() => _settingsVisible = true;

    private void CloseSettings() => _settingsVisible = false;

    private async Task SaveSettingsAsync()
    {
        var newConfig = GetPendingConfig?.Invoke();
        if (newConfig is null || string.IsNullOrEmpty(InstanceId)) return;

        try
        {
            await Http.PutAsJsonAsync($"/api/dashboard/widgets/{InstanceId}/config",
                new WidgetConfigRequest(newConfig));
            _config = newConfig;
            _configError = null;
            await OnConfigLoaded.InvokeAsync(_config);
        }
        catch
        {
            _configError = L["WidgetConfigSaveError"];
        }

        _settingsVisible = false;
    }
}
