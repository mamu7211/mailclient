@using Feirb.Web.Components.UI
@using Feirb.Web.Services
@inject IStringLocalizer<SharedResources> L
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<aside class="feirb-sidebar">
    <!-- User Profile -->
    <AuthorizeView>
        <Authorized>
            <div class="sidebar-profile">
                <div class="profile-avatar">
                    @(context.User.Identity?.Name?[..1].ToUpperInvariant() ?? "?")
                </div>
                <div class="profile-info">
                    <span class="profile-name">@context.User.Identity?.Name</span>
                    <span class="profile-email">@(context.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "")</span>
                </div>
            </div>
        </Authorized>
    </AuthorizeView>

    <!-- Compose Button -->
    <div class="sidebar-compose">
        <NavLink class="btn btn-primary" href="compose">
            <Icon Name="pencil-fill" />
            <span>@L["NavCompose"]</span>
        </NavLink>
    </div>

    <!-- Navigation -->
    <SidebarMenu Sections="_sections" BottomItems="_bottomItems" />
</aside>

@code {
    private IReadOnlyList<SidebarMenuSection> _sections = [];
    private IReadOnlyList<SidebarMenuItem> _bottomItems = [];
    private bool _isAdmin;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAdmin = authState.User.IsInRole("Admin");

        _sections =
        [
            new([new("speedometer2", L["NavDashboard"], Href: "")]),
            new(
            [
                new("inbox", L["NavInbox"], Href: "mail/inbox"),
                new("send", L["NavSent"], Href: "mail/sent"),
                new("pencil-square", L["NavDrafts"], Href: "mail/drafts"),
                new("trash", L["NavTrash"], Href: "mail/trash"),
                new("archive", L["NavArchive"], Href: "mail/archive")
            ], Label: L["NavMain"])
        ];

        _bottomItems =
        [
            new("gear", L["NavSettings"], Href: "settings"),
            new("shield-lock", L["NavAdmin"], Href: "admin", Visible: () => _isAdmin),
            new("box-arrow-right", L["NavLogout"], OnClick: LogoutAsync)
        ];
    }

    private async Task LogoutAsync()
    {
        if (AuthStateProvider is JwtAuthenticationStateProvider jwtProvider)
        {
            await jwtProvider.LogoutAsync();
            Navigation.NavigateTo("/login", forceLoad: true);
        }
    }
}
