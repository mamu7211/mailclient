@using Feirb.Web.Services
@inject IStringLocalizer<SharedResources> L
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<aside class="feirb-sidebar">
    <!-- User Profile -->
    <AuthorizeView>
        <Authorized>
            <div class="sidebar-profile">
                <div class="profile-avatar">
                    @(context.User.Identity?.Name?[..1].ToUpperInvariant() ?? "?")
                </div>
                <div class="profile-info">
                    <span class="profile-name">@context.User.Identity?.Name</span>
                    <span class="profile-email">@(context.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "")</span>
                </div>
            </div>
        </Authorized>
    </AuthorizeView>

    <!-- Navigation -->
    <nav class="sidebar-nav">
        <!-- Main Section -->
        <div class="nav-section">
            <p class="nav-section-label">@L["NavMain"]</p>
            <ul class="nav-list">
                <li>
                    <NavLink class="nav-entry" href="" Match="NavLinkMatch.All">
                        <span class="material-symbols-outlined">inbox</span>
                        <span>@L["NavInbox"]</span>
                    </NavLink>
                </li>
                <li>
                    <NavLink class="nav-entry" href="sent">
                        <span class="material-symbols-outlined">send</span>
                        <span>@L["NavSent"]</span>
                    </NavLink>
                </li>
                <li>
                    <NavLink class="nav-entry" href="drafts">
                        <span class="material-symbols-outlined">draft</span>
                        <span>@L["NavDrafts"]</span>
                    </NavLink>
                </li>
            </ul>
        </div>

        <!-- Folders Section -->
        <div class="nav-section">
            <ul class="nav-list">
                <li>
                    <NavLink class="nav-entry" href="trash">
                        <span class="material-symbols-outlined">delete</span>
                        <span>@L["NavTrash"]</span>
                    </NavLink>
                </li>
                <li>
                    <NavLink class="nav-entry" href="archive">
                        <span class="material-symbols-outlined">archive</span>
                        <span>@L["NavArchive"]</span>
                    </NavLink>
                </li>
            </ul>
        </div>
    </nav>

    <!-- Bottom Section -->
    <div class="sidebar-bottom">
        <div class="sidebar-lang">
            <span class="material-symbols-outlined">language</span>
            <Feirb.Web.Components.LanguageSwitcher ButtonClass="btn-outline-secondary btn-sm" />
        </div>

        <ul class="nav-list">
            <li>
                <NavLink class="nav-entry" href="settings">
                    <span class="material-symbols-outlined">settings</span>
                    <span>@L["NavSettings"]</span>
                </NavLink>
            </li>

            <AuthorizeView Policy="RequireAdmin">
                <Authorized>
                    <li>
                        <NavLink class="nav-entry" href="admin/users">
                            <span class="material-symbols-outlined">admin_panel_settings</span>
                            <span>@L["NavAdmin"]</span>
                        </NavLink>
                    </li>
                </Authorized>
            </AuthorizeView>

            <li>
                <button class="nav-entry nav-entry-button" @onclick="LogoutAsync">
                    <span class="material-symbols-outlined">logout</span>
                    <span>@L["NavLogout"]</span>
                </button>
            </li>
        </ul>
    </div>
</aside>

@code {
    private async Task LogoutAsync()
    {
        if (AuthStateProvider is JwtAuthenticationStateProvider jwtProvider)
        {
            await jwtProvider.LogoutAsync();
            Navigation.NavigateTo("/login", forceLoad: true);
        }
    }
}
