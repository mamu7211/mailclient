@using Feirb.Web.Components.UI
@using Feirb.Web.Services
@inject IStringLocalizer<SharedResources> L
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation
@inject HttpClient Http

<aside class="feirb-sidebar" data-testid="sidebar">
    <!-- User Profile -->
    <AuthorizeView>
        <Authorized>
            <div class="sidebar-profile" data-testid="sidebar-profile">
                <div class="profile-avatar">
                    @(context.User.Identity?.Name?[..1].ToUpperInvariant() ?? "?")
                </div>
                <div class="profile-info">
                    <span class="profile-name" data-testid="profile-name">@context.User.Identity?.Name</span>
                    <span class="profile-email" data-testid="profile-email">@(context.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value ?? "")</span>
                </div>
            </div>
        </Authorized>
    </AuthorizeView>

    <!-- Compose Button -->
    <div class="sidebar-compose">
        <NavLink class="btn btn-primary" href="compose" data-testid="compose-button">
            <Icon Name="pencil-fill" />
            <span>@L["NavCompose"]</span>
        </NavLink>
    </div>

    <!-- Navigation -->
    <SidebarMenu Sections="_sections" BottomItems="_bottomItems" />
</aside>

@code {
    private IReadOnlyList<SidebarMenuSection> _sections = [];
    private IReadOnlyList<SidebarMenuItem> _bottomItems = [];
    private bool _isAdmin;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        _isAdmin = authState.User.IsInRole("Admin");

        _sections =
        [
            new([new("speedometer2", L["NavDashboard"], Href: "", TestId: "nav-dashboard")]),
            new(
            [
                new("inbox", L["NavInbox"], Href: "mail/inbox", TestId: "nav-inbox"),
                new("send", L["NavSent"], Href: "mail/sent", TestId: "nav-sent"),
                new("pencil-square", L["NavDrafts"], Href: "mail/drafts", TestId: "nav-drafts"),
                new("trash", L["NavTrash"], Href: "mail/trash", TestId: "nav-trash"),
                new("archive", L["NavArchive"], Href: "mail/archive", TestId: "nav-archive")
            ], Label: L["NavMain"])
        ];

        _bottomItems =
        [
            new("person-lines-fill", L["AddressBookNavLabel"], Href: "address-book", TestId: "nav-address-book"),
            new("gear", L["NavSettings"], Href: "settings", TestId: "nav-settings"),
            new("shield-lock", L["NavAdmin"], Href: "admin", Visible: () => _isAdmin, TestId: "nav-admin"),
            new("box-arrow-right", L["NavLogout"], OnClick: LogoutAsync, TestId: "nav-logout")
        ];
    }

    private async Task LogoutAsync()
    {
        await Http.PostAsync("/api/auth/logout", null);

        if (AuthStateProvider is JwtAuthenticationStateProvider jwtProvider)
            await jwtProvider.LogoutAsync();

        Navigation.NavigateTo("/login", forceLoad: true);
    }
}
