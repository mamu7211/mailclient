@inherits LayoutComponentBase
@using Feirb.Shared.Settings
@inject HttpClient Http
@inject IJSRuntime Js

<Feirb.Web.Components.ToastContainer />
<Feirb.Web.Components.UnsavedChangesGuard />
<div class="page">
    <NavMenu />
    <main>
        <div class="top-bar">
            <div class="top-bar-row-1">
                <Feirb.Web.Components.Breadcrumb />
                <Feirb.Web.Components.SearchBar />
            </div>
            <Feirb.Web.Components.Toolbar />
        </div>
        <article class="content">
            @Body
        </article>
    </main>
</div>

@code {
    private bool _themeSynced;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_themeSynced)
        {
            _themeSynced = true;
            try
            {
                var prefs = await Http.GetFromJsonAsync<PreferencesResponse>("/api/settings/preferences");
                if (prefs is not null)
                {
                    await Js.InvokeVoidAsync("blazorTheme.set", prefs.Theme);
                }
            }
            catch
            {
                // Not authenticated or API unavailable — keep localStorage theme
            }
        }
    }
}
