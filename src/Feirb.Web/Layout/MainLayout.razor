@inherits LayoutComponentBase
@using Feirb.Shared.Settings
@inject HttpClient Http
@inject IJSRuntime Js

<Feirb.Web.Components.ToastContainer />
<Feirb.Web.Components.UnsavedChangesGuard />
<div class="page">
    <NavMenu />
    <main>
        <div class="top-bar">
            <div class="top-bar-row-1">
                <Feirb.Web.Components.Breadcrumb />
                <Feirb.Web.Components.SearchBar />
            </div>
            <Feirb.Web.Components.Toolbar />
        </div>
        <article class="content">
            @Body
        </article>
    </main>

    @if (_debugPanelOpen)
    {
        <div class="debug-backdrop" @onclick="CloseDebugPanel"></div>
    }

    <div class="debug-drawer @(_debugPanelOpen ? "open" : "")">
        <button type="button" class="debug-tab" @onclick="ToggleDebugPanel">
            <span>Debug</span>
        </button>
        <div class="debug-panel">
            <Feirb.Web.Components.ContentSection Icon="bug" Title="Debug" />
        </div>
    </div>
</div>

@code {
    private bool _debugPanelOpen;

    private void ToggleDebugPanel() => _debugPanelOpen = !_debugPanelOpen;

    private void CloseDebugPanel() => _debugPanelOpen = false;

    private bool _themeSynced;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !_themeSynced)
        {
            _themeSynced = true;
            try
            {
                var prefs = await Http.GetFromJsonAsync<PreferencesResponse>("/api/settings/preferences");
                if (prefs is not null)
                {
                    await Js.InvokeVoidAsync("blazorTheme.set", prefs.Theme);
                }
            }
            catch
            {
                // Not authenticated or API unavailable — keep localStorage theme
            }
        }
    }
}
