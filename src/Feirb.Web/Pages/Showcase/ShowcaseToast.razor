@using Feirb.Web.Components.UI
@using Feirb.Web.Services
@inject IJSRuntime JS
@inject NotificationService NotificationService

<InfoHeader Title="Toast" Icon="bell" Subtitle="Toast notifications for user feedback with auto-dismiss and severity levels" />

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">NotificationService API</Heading>
    <p>
        The <code>NotificationService</code> manages toast notifications. It is registered as a singleton
        and injected into components via <code>@@inject NotificationService NotificationService</code>.
    </p>
    <Table Size="TableSize.Small">
        <TableHeader>
            <TableColumn>Method</TableColumn>
            <TableColumn>Signature</TableColumn>
            <TableColumn>Description</TableColumn>
        </TableHeader>
        <TableBody>
            <TableRow><TableCell><code>Add</code></TableCell><TableCell><code>Add(string message, NotificationSeverity severity)</code></TableCell><TableCell>Shows a toast notification. Returns <code>NotificationItem</code></TableCell></TableRow>
            <TableRow><TableCell><code>Dismiss</code></TableCell><TableCell><code>Dismiss(Guid id)</code></TableCell><TableCell>Manually dismisses a notification by its ID</TableCell></TableRow>
            <TableRow><TableCell><code>Clear</code></TableCell><TableCell><code>Clear()</code></TableCell><TableCell>Removes all active notifications</TableCell></TableRow>
        </TableBody>
    </Table>
</Card>

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">ToastContainer Component</Heading>
    <p>
        The <code>ToastContainer</code> renders active notifications. Place it once in your layout
        (typically at the top of <code>MainLayout.razor</code>, before the page content).
    </p>
    <Table Size="TableSize.Small">
        <TableHeader>
            <TableColumn>Severity</TableColumn>
            <TableColumn>Icon</TableColumn>
            <TableColumn>Auto-dismiss</TableColumn>
            <TableColumn>CSS Class</TableColumn>
        </TableHeader>
        <TableBody>
            <TableRow><TableCell><code>Info</code></TableCell><TableCell><code>info-circle</code></TableCell><TableCell>10 seconds</TableCell><TableCell><code>toast-info</code></TableCell></TableRow>
            <TableRow><TableCell><code>Success</code></TableCell><TableCell><code>check-circle</code></TableCell><TableCell>10 seconds</TableCell><TableCell><code>toast-success</code></TableCell></TableRow>
            <TableRow><TableCell><code>Warning</code></TableCell><TableCell><code>exclamation-triangle</code></TableCell><TableCell>30 seconds</TableCell><TableCell><code>toast-warning</code></TableCell></TableRow>
            <TableRow><TableCell><code>Error</code></TableCell><TableCell><code>exclamation-circle</code></TableCell><TableCell>Manual only</TableCell><TableCell><code>toast-danger</code></TableCell></TableRow>
        </TableBody>
    </Table>
</Card>

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">Preview</Heading>
    <p>Click a button to trigger a live toast notification. Toasts appear in the top-right corner of the page.</p>
    <div class="d-flex flex-wrap align-items-center gap-3 mb-3">
        <label class="form-label mb-0">Message:</label>
        <input type="text" class="form-control form-control-sm" style="width: 20rem;" @bind="_message" />
    </div>
    <div class="d-flex flex-wrap gap-3">
        <Button Variant="ButtonVariant.Secondary" Icon="info-circle"
                OnClick="@(() => ShowToast(NotificationSeverity.Info))">
            Info
        </Button>
        <Button Variant="ButtonVariant.Primary" Icon="check-circle"
                OnClick="@(() => ShowToast(NotificationSeverity.Success))">
            Success
        </Button>
        <Button Variant="ButtonVariant.Warning" Icon="exclamation-triangle"
                OnClick="@(() => ShowToast(NotificationSeverity.Warning))">
            Warning
        </Button>
        <Button Variant="ButtonVariant.Danger" Icon="exclamation-circle"
                OnClick="@(() => ShowToast(NotificationSeverity.Error))">
            Error
        </Button>
    </div>
    <div class="mt-3">
        <Button Variant="ButtonVariant.Secondary" Icon="x-lg"
                OnClick="@(() => NotificationService.Clear())">
            Clear All
        </Button>
    </div>
</Card>

<Card Class="p-4">
    <Heading Level="HeadingLevel.Small">Code</Heading>
    <pre><code class="language-xml" @ref="_codeElement"></code></pre>
</Card>

@code {
    private string _message = "This is a sample notification";
    private ElementReference _codeElement;

    private void ShowToast(NotificationSeverity severity) =>
        NotificationService.Add(_message, severity);

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try { await JS.InvokeVoidAsync("highlightCode", _codeElement, CurrentCode); }
        catch (JSException) { }
    }

    private string CurrentCode => """
        @inject NotificationService NotificationService

        // Show notifications
        NotificationService.Add("File saved", NotificationSeverity.Success);
        NotificationService.Add("Check your input", NotificationSeverity.Warning);
        NotificationService.Add("Something went wrong", NotificationSeverity.Error);
        NotificationService.Add("New mail arrived", NotificationSeverity.Info);

        // Dismiss a specific notification
        var item = NotificationService.Add("Saving...", NotificationSeverity.Info);
        NotificationService.Dismiss(item.Id);

        // Clear all notifications
        NotificationService.Clear();

        // Place ToastContainer in your layout (once):
        <ToastContainer />
        """;
}
