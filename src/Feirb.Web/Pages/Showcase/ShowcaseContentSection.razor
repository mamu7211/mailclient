@using Feirb.Web.Components.UI
@inject IJSRuntime JS

<InfoHeader Title="ContentSection" Icon="layout-text-sidebar" Subtitle="Card with header and body for grouping form content" />

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">Info</Heading>
    <p>Card with a header (icon + heading with optional subtitle) and a body for child content. Used for inline settings sections that don't navigate away.</p>
    <Table Size="TableSize.Small">
        <TableHeader>
            <TableColumn>Parameter</TableColumn>
            <TableColumn>Type</TableColumn>
            <TableColumn>Default</TableColumn>
            <TableColumn>Description</TableColumn>
        </TableHeader>
        <TableBody>
            <TableRow><TableCell><code>Icon</code></TableCell><TableCell><code>string</code></TableCell><TableCell>required</TableCell><TableCell>Icon name without <code>bi-</code> prefix</TableCell></TableRow>
            <TableRow><TableCell><code>Title</code></TableCell><TableCell><code>string</code></TableCell><TableCell>required</TableCell><TableCell>Section title (rendered via Heading)</TableCell></TableRow>
            <TableRow><TableCell><code>Subtitle</code></TableCell><TableCell><code>string?</code></TableCell><TableCell><code>null</code></TableCell><TableCell>Subtitle (rendered via Heading)</TableCell></TableRow>
            <TableRow><TableCell><code>ChildContent</code></TableCell><TableCell><code>RenderFragment?</code></TableCell><TableCell>&#8212;</TableCell><TableCell>Section body content</TableCell></TableRow>
        </TableBody>
    </Table>
</Card>

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">Preview</Heading>
    <div class="d-flex flex-wrap align-items-center gap-3 mb-3">
        <label class="form-label mb-0">Icon:</label>
        <select class="form-select form-select-sm w-auto" @bind="_csIcon">
            <option value="translate">translate</option>
            <option value="palette">palette</option>
            <option value="bell">bell</option>
            <option value="shield-lock">shield-lock</option>
        </select>
        <div class="form-check">
            <input class="form-check-input" type="checkbox" id="csSubtitle" @bind="_csShowSubtitle" />
            <label class="form-check-label" for="csSubtitle">Subtitle</label>
        </div>
    </div>
    <div class="showcase-preview-area">
        <ContentSection
            Icon="@_csIcon"
            Title="Language"
            Subtitle="@(_csShowSubtitle ? "Choose your preferred display language" : null)">
            <p class="mb-0">Section body content goes here.</p>
        </ContentSection>
    </div>
</Card>

<Card Class="p-4">
    <Heading Level="HeadingLevel.Small">Code</Heading>
    <pre><code class="language-xml" @ref="_codeElement"></code></pre>
</Card>

@code {
    private string _csIcon = "translate";
    private bool _csShowSubtitle = true;
    private ElementReference _codeElement;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try { await JS.InvokeVoidAsync("highlightCode", _codeElement, CurrentCode); }
        catch (JSException) { }
    }

    private string CurrentCode
    {
        get
        {
            var subtitle = _csShowSubtitle ? "\n    Subtitle=\"Choose your preferred display language\"" : "";
            return $"""
                <ContentSection
                    Icon="{_csIcon}"
                    Title="Language"{subtitle}>
                    <p>Section body content goes here.</p>
                </ContentSection>
                """;
        }
    }
}
