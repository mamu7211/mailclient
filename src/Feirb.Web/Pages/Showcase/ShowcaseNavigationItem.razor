@using Feirb.Web.Components.UI
@inject IJSRuntime JS

<InfoHeader Title="NavigationItem" Icon="box-arrow-right" Subtitle="Card-style navigation link with icon, title, and chevron" />

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">Info</Heading>
    <p>Card-style navigation link with icon, title, optional subtitle, and chevron. Used in settings and admin index pages to navigate to sub-pages.</p>
    <Table Size="TableSize.Small">
        <TableHeader>
            <TableColumn>Parameter</TableColumn>
            <TableColumn>Type</TableColumn>
            <TableColumn>Default</TableColumn>
            <TableColumn>Description</TableColumn>
        </TableHeader>
        <TableBody>
            <TableRow><TableCell><code>Icon</code></TableCell><TableCell><code>string</code></TableCell><TableCell>required</TableCell><TableCell>Icon name without <code>bi-</code> prefix</TableCell></TableRow>
            <TableRow><TableCell><code>Title</code></TableCell><TableCell><code>string</code></TableCell><TableCell>required</TableCell><TableCell>Navigation item title</TableCell></TableRow>
            <TableRow><TableCell><code>Subtitle</code></TableCell><TableCell><code>string?</code></TableCell><TableCell><code>null</code></TableCell><TableCell>Description text below the title</TableCell></TableRow>
            <TableRow><TableCell><code>Href</code></TableCell><TableCell><code>string</code></TableCell><TableCell>required</TableCell><TableCell>Target URL</TableCell></TableRow>
        </TableBody>
    </Table>
</Card>

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">Preview</Heading>
    <div class="d-flex flex-wrap align-items-center gap-3 mb-3">
        <label class="form-label mb-0">Icon:</label>
        <select class="form-select form-select-sm w-auto" @bind="_navIcon">
            <option value="person">person</option>
            <option value="lock">lock</option>
            <option value="envelope">envelope</option>
            <option value="tag">tag</option>
            <option value="gear">gear</option>
        </select>
        <div class="form-check">
            <input class="form-check-input" type="checkbox" id="navSubtitle" @bind="_navShowSubtitle" />
            <label class="form-check-label" for="navSubtitle">Subtitle</label>
        </div>
    </div>
    <div class="showcase-preview-area">
        <NavigationItem
            Icon="@_navIcon"
            Title="Personal Information"
            Subtitle="@(_navShowSubtitle ? "Update your name and email address" : null)"
            Href="/components-showcase" />
    </div>
</Card>

<Card Class="p-4">
    <Heading Level="HeadingLevel.Small">Code</Heading>
    <pre><code class="language-xml" @ref="_codeElement"></code></pre>
</Card>

@code {
    private string _navIcon = "person";
    private bool _navShowSubtitle = true;
    private ElementReference _codeElement;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try { await JS.InvokeVoidAsync("highlightCode", _codeElement, CurrentCode); }
        catch (JSException) { }
    }

    private string CurrentCode
    {
        get
        {
            var subtitle = _navShowSubtitle ? "\n    Subtitle=\"Update your name and email address\"" : "";
            return $"""
                <NavigationItem
                    Icon="{_navIcon}"
                    Title="Personal Information"{subtitle}
                    Href="/settings/personal-information" />
                """;
        }
    }
}
