@using Feirb.Web.Components.UI
@inject IJSRuntime Js

<InfoHeader Title="Design Fundamentals" Icon="palette2" Subtitle="Color tokens, themes, typography, surfaces, and visual style rules" />

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">Theme System</Heading>
    <p>Feirb ships with <strong>14 predesigned themes</strong> (7 accent colors in light and dark variants). Themes are applied instantly via CSS custom properties on <code>&lt;html data-theme="..."&gt;</code>. The default theme is <strong>Green Light</strong>.</p>
    <p class="mb-0">All UI components reference design tokens (<code>--bs-*</code> and <code>--feirb-*</code> variables) rather than hardcoded colors, so every theme is fully supported without component changes.</p>
</Card>

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">Color Palette</Heading>
    <p class="mb-3">These swatches reflect the <strong>active theme</strong>. Switch themes below to see how tokens change.</p>
    <div class="showcase-color-grid">
        <div class="showcase-color-item">
            <div class="showcase-color-swatch" style="background-color: var(--bs-primary);"></div>
            <div class="showcase-color-info">
                <strong class="showcase-color-name">Primary</strong>
                <code class="showcase-color-token">--bs-primary</code>
                <span class="showcase-color-usage text-muted">CTAs, active states, links</span>
            </div>
        </div>
        <div class="showcase-color-item">
            <div class="showcase-color-swatch" style="background-color: var(--feirb-primary-container);"></div>
            <div class="showcase-color-info">
                <strong class="showcase-color-name">Primary Container</strong>
                <code class="showcase-color-token">--feirb-primary-container</code>
                <span class="showcase-color-usage text-muted">Selection highlights, hover tints</span>
            </div>
        </div>
        <div class="showcase-color-item">
            <div class="showcase-color-swatch" style="background-color: var(--bs-secondary);"></div>
            <div class="showcase-color-info">
                <strong class="showcase-color-name">Secondary</strong>
                <code class="showcase-color-token">--bs-secondary</code>
                <span class="showcase-color-usage text-muted">Secondary buttons, subtle backgrounds</span>
            </div>
        </div>
        <div class="showcase-color-item">
            <div class="showcase-color-swatch" style="background-color: var(--bs-warning);"></div>
            <div class="showcase-color-info">
                <strong class="showcase-color-name">Warning</strong>
                <code class="showcase-color-token">--bs-warning</code>
                <span class="showcase-color-usage text-muted">Warnings, tags, highlights</span>
            </div>
        </div>
        <div class="showcase-color-item">
            <div class="showcase-color-swatch" style="background-color: var(--bs-danger);"></div>
            <div class="showcase-color-info">
                <strong class="showcase-color-name">Error</strong>
                <code class="showcase-color-token">--bs-danger</code>
                <span class="showcase-color-usage text-muted">Danger actions, validation errors</span>
            </div>
        </div>
        <div class="showcase-color-item">
            <div class="showcase-color-swatch" style="background-color: var(--feirb-on-surface);"></div>
            <div class="showcase-color-info">
                <strong class="showcase-color-name">On Surface</strong>
                <code class="showcase-color-token">--feirb-on-surface</code>
                <span class="showcase-color-usage text-muted">Body text, headings</span>
            </div>
        </div>
        <div class="showcase-color-item">
            <div class="showcase-color-swatch" style="background-color: var(--feirb-on-surface-variant);"></div>
            <div class="showcase-color-info">
                <strong class="showcase-color-name">On Surface Variant</strong>
                <code class="showcase-color-token">--feirb-on-surface-variant</code>
                <span class="showcase-color-usage text-muted">Subtitles, secondary text</span>
            </div>
        </div>
        <div class="showcase-color-item">
            <div class="showcase-color-swatch" style="background-color: var(--bs-body-bg); border: 1px solid var(--feirb-border-color-input);"></div>
            <div class="showcase-color-info">
                <strong class="showcase-color-name">Background</strong>
                <code class="showcase-color-token">--bs-body-bg</code>
                <span class="showcase-color-usage text-muted">Page background</span>
            </div>
        </div>
        <div class="showcase-color-item">
            <div class="showcase-color-swatch" style="background-color: var(--feirb-surface);  border: 1px solid var(--feirb-border-color-input);"></div>
            <div class="showcase-color-info">
                <strong class="showcase-color-name">Surface</strong>
                <code class="showcase-color-token">--feirb-surface</code>
                <span class="showcase-color-usage text-muted">Cards, inputs, sidebars</span>
            </div>
        </div>
        <div class="showcase-color-item">
            <div class="showcase-color-swatch" style="background-color: var(--feirb-surface-container);"></div>
            <div class="showcase-color-info">
                <strong class="showcase-color-name">Surface Container</strong>
                <code class="showcase-color-token">--feirb-surface-container</code>
                <span class="showcase-color-usage text-muted">Hover backgrounds, input fills</span>
            </div>
        </div>
    </div>
</Card>

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">Theme Switcher</Heading>
    <p class="mb-3">Preview how the showcase looks under each theme. This changes the active theme globally.</p>
    <div class="d-flex flex-column gap-3">
        <div class="d-flex align-items-center gap-3">
            <label class="form-label fw-semibold mb-0" style="min-width: 4rem;">Light</label>
            <ToggleButtonGroup Items="_lightThemes" SelectedId="@_currentTheme"
                               SelectedIdChanged="OnThemeChangedAsync" />
        </div>
        <div class="d-flex align-items-center gap-3">
            <label class="form-label fw-semibold mb-0" style="min-width: 4rem;">Dark</label>
            <ToggleButtonGroup Items="_darkThemes" SelectedId="@_currentTheme"
                               SelectedIdChanged="OnThemeChangedAsync" />
        </div>
    </div>
</Card>

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">Typography</Heading>
    <p>Primary font is <strong class="showcase-color-name">Inter</strong> with fallbacks to Helvetica Neue, Helvetica, and Arial.</p>
    <Table Size="TableSize.Small">
        <TableHeader>
            <TableColumn>Element</TableColumn>
            <TableColumn>Size</TableColumn>
            <TableColumn>Weight</TableColumn>
        </TableHeader>
        <TableBody>
            <TableRow><TableCell>Heading Large (h1)</TableCell><TableCell>1.75rem</TableCell><TableCell>700</TableCell></TableRow>
            <TableRow><TableCell>Heading Medium (h2)</TableCell><TableCell>1.25rem</TableCell><TableCell>700</TableCell></TableRow>
            <TableRow><TableCell>Heading Small (h3)</TableCell><TableCell>1rem</TableCell><TableCell>700</TableCell></TableRow>
            <TableRow><TableCell>Body text</TableCell><TableCell>1rem (browser default)</TableCell><TableCell>400</TableCell></TableRow>
            <TableRow><TableCell>Subtitle / secondary</TableCell><TableCell>0.875rem</TableCell><TableCell>400</TableCell></TableRow>
            <TableRow><TableCell>Nav section labels</TableCell><TableCell>0.625rem uppercase</TableCell><TableCell>600</TableCell></TableRow>
        </TableBody>
    </Table>
</Card>

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">Surfaces and Elevation</Heading>
    <Table Size="TableSize.Small">
        <TableHeader>
            <TableColumn>Token</TableColumn>
            <TableColumn>Value</TableColumn>
            <TableColumn>Usage</TableColumn>
        </TableHeader>
        <TableBody>
            <TableRow><TableCell>Border radius</TableCell><TableCell><code>1rem</code> (16px)</TableCell><TableCell>Cards, modals</TableCell></TableRow>
            <TableRow><TableCell>Border radius (lg)</TableCell><TableCell><code>1.5rem</code> (24px)</TableCell><TableCell>Large containers</TableCell></TableRow>
            <TableRow><TableCell>Input radius</TableCell><TableCell><code>0.75rem</code> (12px)</TableCell><TableCell>Form controls</TableCell></TableRow>
            <TableRow><TableCell>Button radius</TableCell><TableCell><code>9999px</code></TableCell><TableCell>Pill-shaped buttons</TableCell></TableRow>
            <TableRow><TableCell>Shadow</TableCell><TableCell><code>var(--feirb-shadow)</code></TableCell><TableCell>Cards, primary buttons</TableCell></TableRow>
        </TableBody>
    </Table>
    <p class="mt-3 mb-0"><strong class="showcase-color-name">Layering:</strong> Base background → Raised cards (surface, shadow) → Interactive elements (accent colors)</p>
</Card>

<Card Class="p-4">
    <Heading Level="HeadingLevel.Small">Icons</Heading>
    <p class="mb-2">All icons use <strong class="showcase-color-name">Bootstrap Icons</strong> (<code>bi-*</code>). Never use Google Material Symbols or other icon sets.</p>
    <div class="d-flex align-items-center gap-4">
        <div class="d-flex align-items-center gap-2">
            <Icon Name="gear" Size="IconSize.Small" />
            <span class="showcase-color-usage text-muted">Small (0.875rem)</span>
        </div>
        <div class="d-flex align-items-center gap-2">
            <Icon Name="gear" />
            <span class="showcase-color-usage text-muted">Default (1.25rem)</span>
        </div>
        <div class="d-flex align-items-center gap-2">
            <Icon Name="gear" Size="IconSize.Large" />
            <span class="showcase-color-usage text-muted">Large (2rem)</span>
        </div>
    </div>
</Card>

@code {
    private string _currentTheme = "green-light";

    private static readonly IReadOnlyList<ToggleButtonItem> _lightThemes =
    [
        new("red-light", "Red"),
        new("orange-light", "Orange"),
        new("green-light", "Green"),
        new("teal-light", "Teal"),
        new("blue-light", "Blue"),
        new("purple-light", "Purple"),
        new("pink-light", "Pink"),
    ];

    private static readonly IReadOnlyList<ToggleButtonItem> _darkThemes =
    [
        new("red-dark", "Red"),
        new("orange-dark", "Orange"),
        new("green-dark", "Green"),
        new("teal-dark", "Teal"),
        new("blue-dark", "Blue"),
        new("purple-dark", "Purple"),
        new("pink-dark", "Pink"),
    ];

    protected override async Task OnInitializedAsync()
    {
        _currentTheme = await Js.InvokeAsync<string>("blazorTheme.get");
    }

    private async Task OnThemeChangedAsync(string themeId)
    {
        _currentTheme = themeId;
        await Js.InvokeVoidAsync("blazorTheme.set", themeId);
    }
}
