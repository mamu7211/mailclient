@using Feirb.Web.Components.UI
@inject IJSRuntime JS

<InfoHeader Title="ToggleButtonGroup" Icon="toggles" Subtitle="Mutually exclusive toggle buttons with radio group semantics" />

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">Info</Heading>
    <p>A row of mutually exclusive toggle buttons where exactly one is selected at a time. Uses <code>role="radiogroup"</code> and <code>role="radio"</code> for accessibility. Supports arrow key navigation.</p>
    <Table Size="TableSize.Small">
        <TableHeader>
            <TableColumn>Parameter</TableColumn>
            <TableColumn>Type</TableColumn>
            <TableColumn>Default</TableColumn>
            <TableColumn>Description</TableColumn>
        </TableHeader>
        <TableBody>
            <TableRow><TableCell><code>Items</code></TableCell><TableCell><code>IReadOnlyList&lt;ToggleButtonItem&gt;</code></TableCell><TableCell>&#8212;</TableCell><TableCell>Available options</TableCell></TableRow>
            <TableRow><TableCell><code>SelectedId</code></TableCell><TableCell><code>string</code></TableCell><TableCell>&#8212;</TableCell><TableCell>Currently selected item ID</TableCell></TableRow>
            <TableRow><TableCell><code>SelectedIdChanged</code></TableCell><TableCell><code>EventCallback&lt;string&gt;</code></TableCell><TableCell>&#8212;</TableCell><TableCell>Fires when selection changes</TableCell></TableRow>
            <TableRow><TableCell><code>MaxPerRow</code></TableCell><TableCell><code>int</code></TableCell><TableCell><code>8</code></TableCell><TableCell>Maximum items per row before wrapping</TableCell></TableRow>
            <TableRow><TableCell><code>Class</code></TableCell><TableCell><code>string?</code></TableCell><TableCell><code>null</code></TableCell><TableCell>Extra CSS classes</TableCell></TableRow>
        </TableBody>
    </Table>
</Card>

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">Preview</Heading>
    <div class="d-flex flex-wrap align-items-center gap-3 mb-3">
        <div class="d-flex align-items-center gap-2">
            <label class="form-label mb-0">Items:</label>
            <CircularButton AriaLabel="Remove item" Variant="ButtonVariant.Secondary" Size="ButtonSize.Small"
                            Disabled="@(_itemCount <= 1)" OnClick="RemoveItem">
                <Icon Name="dash" Size="IconSize.Small" />
            </CircularButton>
            <span class="fw-semibold">@_itemCount</span>
            <CircularButton AriaLabel="Add item" Variant="ButtonVariant.Secondary" Size="ButtonSize.Small"
                            Disabled="@(_itemCount >= 20)" OnClick="AddItem">
                <Icon Name="plus" Size="IconSize.Small" />
            </CircularButton>
        </div>
        <div class="d-flex align-items-center gap-2">
            <label class="form-label mb-0">Max per row:</label>
            <CircularButton AriaLabel="Decrease max per row" Variant="ButtonVariant.Secondary" Size="ButtonSize.Small"
                            Disabled="@(_maxPerRow <= 2)" OnClick="() => _maxPerRow--">
                <Icon Name="dash" Size="IconSize.Small" />
            </CircularButton>
            <span class="fw-semibold">@_maxPerRow</span>
            <CircularButton AriaLabel="Increase max per row" Variant="ButtonVariant.Secondary" Size="ButtonSize.Small"
                            Disabled="@(_maxPerRow >= 20)" OnClick="() => _maxPerRow++">
                <Icon Name="plus" Size="IconSize.Small" />
            </CircularButton>
        </div>
    </div>
    <div class="showcase-preview-area">
        <ToggleButtonGroup Items="VisibleItems" MaxPerRow="_maxPerRow" @bind-SelectedId="_selectedId" />
        <p class="text-muted mt-2 mb-0">Selected: <strong>@_selectedId</strong></p>
    </div>
</Card>

<Card Class="p-4">
    <Heading Level="HeadingLevel.Small">Code</Heading>
    <pre><code class="language-xml" @ref="_codeElement"></code></pre>
</Card>

@code {
    private int _itemCount = 3;
    private int _maxPerRow = 8;
    private string _selectedId = "option-1";
    private ElementReference _codeElement;

    private IReadOnlyList<ToggleButtonItem> VisibleItems =>
        Enumerable.Range(1, _itemCount).Select(i => new ToggleButtonItem($"option-{i}", $"Option {i}")).ToList();

    private void AddItem()
    {
        if (_itemCount < 20) _itemCount++;
    }

    private void RemoveItem()
    {
        if (_itemCount <= 1) return;
        _itemCount--;
        if (!VisibleItems.Any(i => i.Id == _selectedId))
        {
            _selectedId = VisibleItems[^1].Id;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try { await JS.InvokeVoidAsync("highlightCode", _codeElement, CurrentCode); }
        catch (JSException) { }
    }

    private string CurrentCode
    {
        get
        {
            var items = string.Join(",\n        ", VisibleItems.Select(i => $"new(\"{i.Id}\", \"{i.Label}\")"));
            var maxAttr = _maxPerRow != 8 ? $"\n    MaxPerRow=\"{_maxPerRow}\"" : "";
            return "<ToggleButtonGroup Items=\"_items\"" + maxAttr + "\n" +
                   "    @bind-SelectedId=\"_selectedId\" />\n" +
                   "\n" +
                   "@code {\n" +
                   $"    private string _selectedId = \"{_selectedId}\";\n" +
                   "\n" +
                   "    private static readonly IReadOnlyList<ToggleButtonItem> _items =\n" +
                   "    [\n" +
                   $"        {items}\n" +
                   "    ];\n" +
                   "}";
        }
    }
}
