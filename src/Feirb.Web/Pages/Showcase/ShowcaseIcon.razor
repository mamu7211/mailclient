@using Feirb.Web.Components.UI
@inject IJSRuntime JS

<InfoHeader Title="Icon" Icon="image" Subtitle="Bootstrap Icon with consistent sizing" />

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">Info</Heading>
    <p>Renders a Bootstrap Icon with consistent sizing. Wraps <code>&lt;i class="bi bi-..."&gt;</code> with standardized size classes.</p>
    <Table Size="TableSize.Small">
        <TableHeader>
            <TableColumn>Parameter</TableColumn>
            <TableColumn>Type</TableColumn>
            <TableColumn>Default</TableColumn>
            <TableColumn>Description</TableColumn>
        </TableHeader>
        <TableBody>
            <TableRow><TableCell><code>Name</code></TableCell><TableCell><code>string</code></TableCell><TableCell>required</TableCell><TableCell>Icon name without <code>bi-</code> prefix</TableCell></TableRow>
            <TableRow><TableCell><code>Size</code></TableCell><TableCell><code>IconSize</code></TableCell><TableCell><code>Default</code></TableCell><TableCell>Small (0.875rem), Default (1.25rem), Large (2rem)</TableCell></TableRow>
            <TableRow><TableCell><code>Class</code></TableCell><TableCell><code>string?</code></TableCell><TableCell><code>null</code></TableCell><TableCell>Extra CSS classes</TableCell></TableRow>
        </TableBody>
    </Table>
</Card>

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">Preview</Heading>
    <div class="d-flex align-items-center gap-3 mb-3">
        <label class="form-label mb-0">Size:</label>
        <select class="form-select form-select-sm w-auto" @bind="_iconSize">
            <option value="@IconSize.Small">Small</option>
            <option value="@IconSize.Default">Default</option>
            <option value="@IconSize.Large">Large</option>
        </select>
        <label class="form-label mb-0">Name:</label>
        <select class="form-select form-select-sm w-auto" @bind="_iconName">
            @foreach (var name in FeirbIcons.All)
            {
                <option value="@name">@name</option>
            }
        </select>
    </div>
    <div class="showcase-preview-area">
        <Icon Name="@_iconName" Size="@_iconSize" />
    </div>
</Card>

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">Code</Heading>
    <pre><code class="language-xml" @ref="_codeElement"></code></pre>
</Card>

<Card Class="p-4">
    <Heading Level="HeadingLevel.Small">Icon Search</Heading>
    <p class="text-muted mb-3">@FeirbIcons.All.Count icons available in Feirb. Click to select.</p>
    <div class="mb-3">
        <input type="text"
               class="form-control"
               placeholder="Search icons..."
               @bind="_searchQuery"
               @bind:event="oninput" />
    </div>
    <div class="showcase-icon-grid">
        @foreach (var name in FilteredIcons)
        {
            <button class="showcase-icon-cell @(name == _iconName ? "active" : "")"
                    title="@name"
                    @onclick="() => SelectIcon(name)">
                <Icon Name="@name" />
                <span class="showcase-icon-label">@name</span>
            </button>
        }
        @if (!FilteredIcons.Any())
        {
            <p class="text-muted mb-0">No icons match "@_searchQuery".</p>
        }
    </div>
</Card>

@code {
    private IconSize _iconSize = IconSize.Default;
    private string _iconName = "gear";
    private string _searchQuery = "";
    private ElementReference _codeElement;

    private IEnumerable<string> FilteredIcons =>
        string.IsNullOrWhiteSpace(_searchQuery)
            ? FeirbIcons.All
            : FeirbIcons.All.Where(n => n.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase));

    private void SelectIcon(string name) => _iconName = name;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try { await JS.InvokeVoidAsync("highlightCode", _codeElement, CurrentCode); }
        catch (JSException) { }
    }

    private string CurrentCode =>
        $"""<Icon Name="{_iconName}"{(_iconSize != IconSize.Default ? $" Size=\"IconSize.{_iconSize}\"" : "")} />""";
}
