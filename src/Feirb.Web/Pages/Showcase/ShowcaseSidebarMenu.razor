@using Feirb.Web.Components.UI
@inject IJSRuntime JS

<InfoHeader Title="SidebarMenu" Icon="layout-sidebar" Subtitle="Data-driven sidebar navigation with sections and active state tracking" />

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">Info</Heading>
    <p>Data-driven sidebar navigation with optional section headers and a bottom-pinned slot. Uses <code>NavLink</code> internally for link items with automatic active state tracking. Items can alternatively render as buttons via an <code>OnClick</code> callback.</p>
    <Table Size="TableSize.Small">
        <TableHeader>
            <TableColumn>Parameter</TableColumn>
            <TableColumn>Type</TableColumn>
            <TableColumn>Default</TableColumn>
            <TableColumn>Description</TableColumn>
        </TableHeader>
        <TableBody>
            <TableRow><TableCell><code>Sections</code></TableCell><TableCell><code>IReadOnlyList&lt;SidebarMenuSection&gt;</code></TableCell><TableCell>required</TableCell><TableCell>Menu sections for the main scrollable area</TableCell></TableRow>
            <TableRow><TableCell><code>BottomItems</code></TableCell><TableCell><code>IReadOnlyList&lt;SidebarMenuItem&gt;?</code></TableCell><TableCell><code>null</code></TableCell><TableCell>Items pinned to the bottom of the sidebar</TableCell></TableRow>
            <TableRow><TableCell><code>AriaLabel</code></TableCell><TableCell><code>string</code></TableCell><TableCell><code>"Sidebar navigation"</code></TableCell><TableCell>Accessible label for the nav element</TableCell></TableRow>
            <TableRow><TableCell><code>Class</code></TableCell><TableCell><code>string?</code></TableCell><TableCell><code>null</code></TableCell><TableCell>Extra CSS classes</TableCell></TableRow>
        </TableBody>
    </Table>
</Card>

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">SidebarMenuItem</Heading>
    <Table Size="TableSize.Small">
        <TableHeader>
            <TableColumn>Property</TableColumn>
            <TableColumn>Type</TableColumn>
            <TableColumn>Description</TableColumn>
        </TableHeader>
        <TableBody>
            <TableRow><TableCell><code>Icon</code></TableCell><TableCell><code>string</code></TableCell><TableCell>Bootstrap Icon name (required)</TableCell></TableRow>
            <TableRow><TableCell><code>Label</code></TableCell><TableCell><code>string</code></TableCell><TableCell>Display text (required)</TableCell></TableRow>
            <TableRow><TableCell><code>Href</code></TableCell><TableCell><code>string?</code></TableCell><TableCell>Navigation target; rendered via NavLink</TableCell></TableRow>
            <TableRow><TableCell><code>OnClick</code></TableCell><TableCell><code>Func&lt;Task&gt;?</code></TableCell><TableCell>Action callback; renders as button when set</TableCell></TableRow>
            <TableRow><TableCell><code>Visible</code></TableCell><TableCell><code>Func&lt;bool&gt;?</code></TableCell><TableCell>Controls visibility; defaults to always visible</TableCell></TableRow>
        </TableBody>
    </Table>
</Card>

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">SidebarMenuSection</Heading>
    <Table Size="TableSize.Small">
        <TableHeader>
            <TableColumn>Property</TableColumn>
            <TableColumn>Type</TableColumn>
            <TableColumn>Description</TableColumn>
        </TableHeader>
        <TableBody>
            <TableRow><TableCell><code>Items</code></TableCell><TableCell><code>IReadOnlyList&lt;SidebarMenuItem&gt;</code></TableCell><TableCell>Menu items in this section (required)</TableCell></TableRow>
            <TableRow><TableCell><code>Label</code></TableCell><TableCell><code>string?</code></TableCell><TableCell>Optional section header text</TableCell></TableRow>
        </TableBody>
    </Table>
</Card>

<Card Class="mb-3 p-4">
    <Heading Level="HeadingLevel.Small">Preview</Heading>
    <p class="text-muted mb-3">The sidebar on this page is a live example of SidebarMenu. The main app NavMenu also uses it.</p>
    <div class="showcase-preview-area">
        <div class="showcase-navmenu-demo">
            <p class="px-3 mb-2" style="font-size: 0.625rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--feirb-on-surface-variant); font-weight: 600;">Main</p>
            @foreach (var (icon, label) in new[] { ("inbox", "Inbox"), ("send", "Sent"), ("pencil-square", "Drafts") })
            {
                <div class="d-flex align-items-center gap-3 px-3 py-2" style="color: var(--feirb-on-surface-variant); font-size: 0.875rem; font-weight: 500;">
                    <Icon Name="@icon" /> <span>@label</span>
                </div>
            }
            <div class="mt-3 pt-3" style="border-top: 1px solid rgba(0,0,0,0.08);">
                <div class="d-flex align-items-center gap-3 px-3 py-2" style="color: var(--feirb-on-surface-variant); font-size: 0.875rem; font-weight: 500;">
                    <Icon Name="gear" /> <span>Settings</span>
                </div>
            </div>
        </div>
    </div>
</Card>

<Card Class="p-4">
    <Heading Level="HeadingLevel.Small">Code</Heading>
    <pre><code class="language-xml" @ref="_codeElement"></code></pre>
</Card>

@code {
    private ElementReference _codeElement;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try { await JS.InvokeVoidAsync("highlightCode", _codeElement, CurrentCode); }
        catch (JSException) { }
    }

    private static string CurrentCode =>
        """
        <SidebarMenu Sections="_sections" BottomItems="_bottomItems" />

        @code {
            private IReadOnlyList<SidebarMenuSection> _sections =
            [
                new([new("speedometer2", "Dashboard", Href: "")]),
                new(
                [
                    new("inbox", "Inbox", Href: "mail/inbox"),
                    new("send", "Sent", Href: "mail/sent")
                ], Label: "Main")
            ];

            private IReadOnlyList<SidebarMenuItem> _bottomItems =
            [
                new("gear", "Settings", Href: "settings"),
                new("box-arrow-right", "Logout", OnClick: LogoutAsync)
            ];
        }
        """;
}
