@page "/mail/inbox"
@attribute [Authorize]
@using Feirb.Shared.Mail
@using Feirb.Web.Components
@using Feirb.Web.Components.UI
@using Feirb.Web.Services
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResources> L
@inject ViewportService Viewport
@implements IDisposable

<PageTitle>@L["PageTitleInbox"]</PageTitle>

<InfoHeader Title="@L["NavInbox"]" Icon="inbox" Subtitle="@L["PageSubtitleInbox"]">
    <HelpContent>@L["PageHelpInbox"]</HelpContent>
</InfoHeader>

@if (_isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">@L["LoadingMessages"]</span>
        </div>
        <p class="mt-2 text-muted">@L["LoadingMessages"]</p>
    </div>
}
else if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger" role="alert">@_errorMessage</div>
}
else if (_messages is null || _messages.Items.Count == 0)
{
    <p class="text-muted">@L["NoMessagesFound"]</p>
}
else if (UseCardLayout)
{
    <div class="d-flex flex-column gap-2">
        @foreach (var msg in _messages.Items)
        {
            <MailCard Mode="MailCardMode.Small"
                      SenderName="@msg.FromName"
                      SenderEmail="@msg.FromEmail"
                      Subject="@msg.Subject"
                      Summary="@msg.Summary"
                      Labels="@msg.Labels.Select(l => new MailCardLabel(l.Name, l.Color)).ToList()"
                      ReceivedAt="msg.Date.LocalDateTime"
                      IsRead="msg.IsRead"
                      Href="@($"/mail/inbox/{msg.Id}")" />
        }
    </div>

    <Pagination CurrentPage="_currentPage"
                TotalPages="TotalPages"
                CurrentPageChanged="OnPageChangedAsync"
                PageSize="_pageSize"
                PageSizeChanged="OnPageSizeChangedAsync"
                PreviousLabel="@L["PaginationPrevious"]"
                NextLabel="@L["PaginationNext"]"
                PerPageLabel="@L["PaginationPerPage"]"
                Sticky />
}
else
{
    <ContentSection Title="@L["NavInbox"]" Icon="envelope">
        <Table Hover>
            <TableHeader>
                <TableColumn Width="auto">@L["ColumnMailbox"]</TableColumn>
                <TableColumn Width="auto">@L["ColumnFrom"]</TableColumn>
                <TableColumn Width="1fr">@L["ColumnSubject"]</TableColumn>
                <TableColumn Width="auto">@L["ColumnCategory"]</TableColumn>
                <TableColumn Width="auto">@L["ColumnDate"]</TableColumn>
            </TableHeader>
            <TableBody>
                @foreach (var msg in _messages.Items)
                {
                    <TableRow OnClick="() => NavigateToMessage(msg.Id)"
                              OnKeyDown="e => OnRowKeyDownAsync(e, msg.Id)"
                              role="button" tabindex="0">
                        <TableCell>
                            <MailboxChip Name="@msg.MailboxName" Color="@msg.MailboxBadgeColor" />
                        </TableCell>
                        <TableCell>
                            <PersonChip Name="@msg.FromName" Email="@msg.FromEmail" Size="PersonChipSize.Small" />
                        </TableCell>
                        <TableCell Class="inbox-subject-cell">
                            <MailSubjectChip Subject="@msg.Subject"
                                             Summary="@msg.Summary"
                                             IsRead="msg.IsRead"
                                             HasAttachments="msg.HasAttachments" />
                        </TableCell>
                        <TableCell>
                            <div class="d-flex flex-column align-items-start gap-1">
                                @if (msg.Labels.Count > 0)
                                {
                                    @foreach (var label in msg.Labels)
                                    {
                                        <LabelPill Name="@label.Name" Color="@label.Color" Size="LabelPillSize.Small" />
                                    }
                                }
                                else
                                {
                                    <LabelPill Name="@L["LabelNone"]" Color="#6c757d" Size="LabelPillSize.Small" />
                                }
                            </div>
                        </TableCell>
                        <TableCell>
                            <DateTimeChip Value="msg.Date"
                                          DateFormat="@L["DateFormatShort"]"
                                          TimeFormat="@L["TimeFormatShort"]" />
                        </TableCell>
                    </TableRow>
                }
            </TableBody>
        </Table>
    </ContentSection>

    <Pagination CurrentPage="_currentPage"
                TotalPages="TotalPages"
                CurrentPageChanged="OnPageChangedAsync"
                PageSize="_pageSize"
                PageSizeChanged="OnPageSizeChangedAsync"
                PreviousLabel="@L["PaginationPrevious"]"
                NextLabel="@L["PaginationNext"]"
                PerPageLabel="@L["PaginationPerPage"]"
                Sticky />
}

@code {
    private const int CardLayoutBreakpoint = 1100;

    private PaginatedResponse<MessageListItemResponse>? _messages;
    private bool _isLoading = true;
    private string? _errorMessage;
    private int _currentPage = 1;
    private int _pageSize = 5;

    private bool UseCardLayout => Viewport.Width > 0 && Viewport.Width < CardLayoutBreakpoint;

    private int TotalPages => _messages is null || _messages.TotalCount == 0
        ? 1
        : (int)Math.Ceiling((double)_messages.TotalCount / _pageSize);

    protected override async Task OnInitializedAsync() =>
        await LoadMessagesAsync();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Viewport.InitializeAsync();
            Viewport.OnResize += OnViewportResize;
            StateHasChanged();
        }
    }

    private void OnViewportResize() => InvokeAsync(StateHasChanged);

    private async Task LoadMessagesAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        try
        {
            _messages = await Http.GetFromJsonAsync<PaginatedResponse<MessageListItemResponse>>(
                $"/api/mail/messages?page={_currentPage}&pageSize={_pageSize}");
        }
        catch
        {
            _errorMessage = L["ErrorLoadFailed"];
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task OnPageChangedAsync(int page)
    {
        _currentPage = page;
        await LoadMessagesAsync();
    }

    private async Task OnPageSizeChangedAsync(int size)
    {
        _pageSize = size;
        _currentPage = 1;
        await LoadMessagesAsync();
    }

    private void OnRowKeyDownAsync(KeyboardEventArgs e, Guid id)
    {
        if (e.Key is "Enter" or " ")
            NavigateToMessage(id);
    }

    private void NavigateToMessage(Guid id) =>
        Navigation.NavigateTo($"/mail/inbox/{id}");

    public void Dispose() => Viewport.OnResize -= OnViewportResize;
}
