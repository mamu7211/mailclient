@page "/reset-password/{Token}"
@layout AuthLayout
@attribute [AllowAnonymous]
@using Feirb.Shared.Auth
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["PageTitleResetPassword"]</PageTitle>

<div class="position-relative w-100">
    <div class="position-absolute top-0 end-0 p-3">
        <Feirb.Web.Components.LanguageSwitcher ButtonClass="btn-outline-secondary" />
    </div>
    <div class="d-flex align-items-center justify-content-center" style="min-height: 100vh;">
        <div class="card p-4 p-md-5" style="width: 100%; max-width: 440px;">
            <div class="text-center mb-4">
                <h1 class="fw-bold fs-2 text-primary mb-0">@L["AppName"]</h1>
            </div>
            @if (_tokenInvalid)
            {
                <h2 class="mb-1 text-center fw-bold">@L["RequestResetHeading"]</h2>
                <div class="alert alert-danger py-2" role="alert">@L["ErrorResetFailed"]</div>
                <div class="mt-3 text-center">
                    <a href="/login" class="text-muted small">@L["BackToLogin"]</a>
                </div>
            }
            else if (_isLoading)
            {
                <div class="text-center py-4">
                    <span class="spinner-border text-primary" role="status"></span>
                </div>
            }
            else
            {
                <h2 class="mb-1 text-center fw-bold">@L["ResetPasswordHeading"]</h2>
                <p class="text-center text-muted mb-4">@L["ResetPasswordSubheading"]</p>

                @if (!string.IsNullOrEmpty(_errorMessage))
                {
                    <div class="alert alert-danger py-2" role="alert">@_errorMessage</div>
                }

                <EditForm Model="_model" OnValidSubmit="HandleSubmitAsync" FormName="resetPassword">
                    <DataAnnotationsValidator />

                    <div class="mb-3">
                        <label for="newPassword" class="form-label small fw-medium">@L["LabelNewPassword"]</label>
                        <InputText id="newPassword" class="form-control form-control-lg" type="password" placeholder="@L["PlaceholderNewPassword"]" @bind-Value="_model.NewPassword" />
                        <ValidationMessage For="() => _model.NewPassword" />
                    </div>

                    <div class="mb-4">
                        <label for="confirmPassword" class="form-label small fw-medium">@L["LabelConfirmPassword"]</label>
                        <InputText id="confirmPassword" class="form-control form-control-lg" type="password" placeholder="@L["PlaceholderConfirmPassword"]" @bind-Value="_model.ConfirmPassword" />
                        @if (_model.ConfirmPassword is not null && _model.NewPassword != _model.ConfirmPassword)
                        {
                            <div class="validation-message">@L["ErrorPasswordsDoNotMatch"]</div>
                        }
                    </div>

                    <Button Variant="ButtonVariant.Primary" Size="ButtonSize.Large" Type="submit" Disabled="_isSubmitting" Class="w-100">
                        @if (_isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        }
                        @L["ButtonResetPassword"]
                    </Button>
                </EditForm>

                <div class="mt-3 text-center">
                    <a href="/login" class="text-muted small">@L["BackToLogin"]</a>
                </div>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string Token { get; set; } = string.Empty;

    private readonly ResetPasswordFormModel _model = new();
    private string? _errorMessage;
    private bool _isSubmitting;
    private bool _isLoading = true;
    private bool _tokenInvalid;

    protected override async Task OnInitializedAsync()
    {
        var response = await Http.GetAsync($"/api/auth/validate-reset-token/{Token}");
        _tokenInvalid = !response.IsSuccessStatusCode;
        _isLoading = false;
    }

    private async Task HandleSubmitAsync()
    {
        if (_model.NewPassword != _model.ConfirmPassword)
        {
            _errorMessage = L["ErrorPasswordsDoNotMatch"];
            return;
        }

        _isSubmitting = true;
        _errorMessage = null;

        var request = new ResetPasswordRequest(Token, _model.NewPassword!);
        var response = await Http.PostAsJsonAsync("/api/auth/reset-password", request);

        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/login?reset=true");
        }
        else
        {
            _errorMessage = L["ErrorResetFailed"];
        }

        _isSubmitting = false;
    }

    private sealed class ResetPasswordFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MinLength(8)]
        public string? NewPassword { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        public string? ConfirmPassword { get; set; }
    }
}
