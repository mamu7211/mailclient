@page "/settings/mailboxes/{Id:guid}"
@attribute [Authorize]
@using Feirb.Shared.Settings
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResources> L
@inject ToolbarStateService ToolbarState
@inject NotificationService Notifications
@implements IDisposable

<PageTitle>@L["PageTitleEditMailbox"]</PageTitle>

<InfoHeader Title="@L["PageTitleEditMailbox"]" Icon="envelope" Subtitle="@L["PageSubtitleEditMailbox"]">
    <HelpContent>@L["PageHelpEditMailbox"]</HelpContent>
</InfoHeader>

@if (!string.IsNullOrEmpty(_successMessage))
{
    <div class="alert alert-success alert-dismissible py-2" role="alert">
        @_successMessage
        <button type="button" class="btn-close" @onclick="() => _successMessage = null"></button>
    </div>
}

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger alert-dismissible py-2" role="alert">
        @_errorMessage
        <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
    </div>
}

@if (_isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">@L["LoadingMailboxes"]</span>
        </div>
    </div>
}
else if (_model is not null)
{
    <TrackedEditForm Model="_model" OnSave="HandleSaveAsync">
        <DataAnnotationsValidator />

        <ContentSection Icon="info-circle" Title="@L["MailboxSectionGeneral"]" Subtitle="@L["SectionMailboxGeneralSubtitle"]" Class="mb-4">
            <div class="mb-3">
                <label for="name" class="form-label">@L["LabelMailboxName"]</label>
                <InputText id="name" class="form-control" @bind-Value="_model.Name" placeholder="@L["PlaceholderMailboxName"]" />
                <ValidationMessage For="() => _model.Name" />
            </div>
            <div class="mb-3">
                <label for="email" class="form-label">@L["LabelEmailAddress"]</label>
                <InputText id="email" class="form-control" type="email" @bind-Value="_model.EmailAddress" placeholder="@L["PlaceholderEmailAddress"]" />
                <ValidationMessage For="() => _model.EmailAddress" />
            </div>
            <div class="mb-3">
                <label for="displayName" class="form-label">@L["LabelDisplayName"]</label>
                <InputText id="displayName" class="form-control" @bind-Value="_model.DisplayName" placeholder="@L["PlaceholderDisplayName"]" />
            </div>
        </ContentSection>

        <ContentSection Icon="inbox" Title="@L["MailboxSectionImap"]" Subtitle="@L["SectionMailboxImapSubtitle"]" Class="mb-4">
            <div class="row mb-3">
                <div class="col-md-8">
                    <label for="imapHost" class="form-label">@L["LabelImapHost"]</label>
                    <InputText id="imapHost" class="form-control" @bind-Value="_model.ImapHost" placeholder="@L["PlaceholderImapHost"]" />
                    <ValidationMessage For="() => _model.ImapHost" />
                </div>
                <div class="col-md-4">
                    <label for="imapPort" class="form-label">@L["LabelImapPort"]</label>
                    <InputNumber id="imapPort" class="form-control" @bind-Value="_model.ImapPort" />
                    <ValidationMessage For="() => _model.ImapPort" />
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-6">
                    <label for="imapUsername" class="form-label">@L["LabelImapUsername"]</label>
                    <InputText id="imapUsername" class="form-control" @bind-Value="_model.ImapUsername" />
                    <ValidationMessage For="() => _model.ImapUsername" />
                </div>
                <div class="col-md-6">
                    <label for="imapPassword" class="form-label">@L["LabelImapPassword"]</label>
                    <InputText id="imapPassword" class="form-control" type="password" @bind-Value="_model.ImapPassword"
                        placeholder="@L["PasswordPlaceholderKeep"]" />
                </div>
            </div>
            <div class="d-flex justify-content-between align-items-center">
                <div class="form-check">
                    <InputCheckbox id="imapUseTls" class="form-check-input" @bind-Value="_model.ImapUseTls" />
                    <label for="imapUseTls" class="form-check-label">@L["LabelImapUseTls"]</label>
                </div>
                <Button Variant="ButtonVariant.Secondary" Size="ButtonSize.Small" OnClick="TestImapAsync" Disabled="_isTestingImap">
                    @if (_isTestingImap)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    @L["ButtonTestConnection"]
                </Button>
            </div>
            @if (_imapTestResult is not null)
            {
                <div class="alert @(_imapTestResult.Success ? "alert-success" : "alert-danger") mt-3 mb-0 py-2">
                    @GetTestResultMessage(_imapTestResult)
                </div>
            }
        </ContentSection>

        <ContentSection Icon="inbox" Title="@L["MailboxSectionSmtp"]" Subtitle="@L["SectionMailboxSmtpSubtitle"]" Class="mb-4">
            <div class="row mb-3">
                <div class="col-md-8">
                    <label for="smtpHost" class="form-label">@L["LabelSmtpHostMailbox"]</label>
                    <InputText id="smtpHost" class="form-control" @bind-Value="_model.SmtpHost" placeholder="@L["PlaceholderSmtpHostMailbox"]" />
                    <ValidationMessage For="() => _model.SmtpHost" />
                </div>
                <div class="col-md-4">
                    <label for="smtpPort" class="form-label">@L["LabelSmtpPortMailbox"]</label>
                    <InputNumber id="smtpPort" class="form-control" @bind-Value="_model.SmtpPort" />
                    <ValidationMessage For="() => _model.SmtpPort" />
                </div>
            </div>
            <div class="row mb-3">
                <div class="col-md-6">
                    <label for="smtpUsername" class="form-label">@L["LabelSmtpUsernameMailbox"]</label>
                    <InputText id="smtpUsername" class="form-control" @bind-Value="_model.SmtpUsername" />
                    <ValidationMessage For="() => _model.SmtpUsername" />
                </div>
                <div class="col-md-6">
                    <label for="smtpPassword" class="form-label">@L["LabelSmtpPasswordMailbox"]</label>
                    <InputText id="smtpPassword" class="form-control" type="password" @bind-Value="_model.SmtpPassword"
                        placeholder="@L["PasswordPlaceholderKeep"]" />
                </div>
            </div>
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="form-check">
                        <InputCheckbox id="smtpUseTls" class="form-check-input" @bind-Value="_model.SmtpUseTls" />
                        <label for="smtpUseTls" class="form-check-label">@L["LabelSmtpUseTlsMailbox"]</label>
                    </div>
                    <div class="form-check">
                        <InputCheckbox id="smtpRequiresAuth" class="form-check-input" @bind-Value="_model.SmtpRequiresAuth" />
                        <label for="smtpRequiresAuth" class="form-check-label">@L["LabelSmtpRequiresAuthMailbox"]</label>
                    </div>
                </div>
                <Button Variant="ButtonVariant.Secondary" Size="ButtonSize.Small" OnClick="TestSmtpAsync" Disabled="_isTestingSmtp">
                    @if (_isTestingSmtp)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    @L["ButtonTestConnection"]
                </Button>
            </div>
            @if (_smtpTestResult is not null)
            {
                <div class="alert @(_smtpTestResult.Success ? "alert-success" : "alert-danger") mt-3 mb-0 py-2">
                    @GetTestResultMessage(_smtpTestResult)
                </div>
            }
        </ContentSection>
    </TrackedEditForm>
}

@* Delete Confirmation Modal *@
@if (_showDeleteModal)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@L["ConfirmDeleteMailboxTitle"]</h5>
                    <button type="button" class="btn-close" @onclick="() => _showDeleteModal = false"></button>
                </div>
                <div class="modal-body">
                    <p>@string.Format(L["ConfirmDeleteMailboxMessage"], _model?.Name)</p>
                </div>
                <div class="modal-footer">
                    <Button Variant="ButtonVariant.Secondary" OnClick="() => _showDeleteModal = false">@L["ButtonCancel"]</Button>
                    <Button Variant="ButtonVariant.Danger" OnClick="HandleDeleteAsync" Disabled="_isDeleting">
                        @if (_isDeleting)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        }
                        @L["ButtonConfirm"]
                    </Button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private MailboxFormModel? _model;
    private bool _isLoading = true;
    private bool _isSaving;
    private bool _isDeleting;
    private bool _showDeleteModal;
    private string? _successMessage;
    private string? _errorMessage;

    private bool _isTestingImap;
    private bool _isTestingSmtp;
    private TestConnectionResponse? _imapTestResult;
    private TestConnectionResponse? _smtpTestResult;

    private ToolbarAction[] _toolbarActions = [];

    protected override async Task OnInitializedAsync()
    {
        _toolbarActions =
        [
            new ToolbarAction(L["ButtonCancel"], ButtonVariant.Warning, () => { Navigation.NavigateTo("/settings/mailboxes"); return Task.CompletedTask; }, "x-lg"),
            new ToolbarAction(L["ButtonSave"], ButtonVariant.Primary, async () => { await HandleSaveAsync(); }, "check-lg"),
            new ToolbarAction(L["ButtonDelete"], ButtonVariant.Danger, () => { _showDeleteModal = true; StateHasChanged(); return Task.CompletedTask; }, "trash")
        ];
        ToolbarState.AddActions(_toolbarActions);

        try
        {
            var mailbox = await Http.GetFromJsonAsync<MailboxDetailResponse>($"/api/settings/mailboxes/{Id}");
            if (mailbox is not null)
            {
                _model = new MailboxFormModel
                {
                    Name = mailbox.Name,
                    EmailAddress = mailbox.EmailAddress,
                    DisplayName = mailbox.DisplayName,
                    ImapHost = mailbox.ImapHost,
                    ImapPort = mailbox.ImapPort,
                    ImapUsername = mailbox.ImapUsername,
                    ImapUseTls = mailbox.ImapUseTls,
                    SmtpHost = mailbox.SmtpHost,
                    SmtpPort = mailbox.SmtpPort,
                    SmtpUsername = mailbox.SmtpUsername,
                    SmtpUseTls = mailbox.SmtpUseTls,
                    SmtpRequiresAuth = mailbox.SmtpRequiresAuth,
                };
            }
        }
        catch
        {
            _errorMessage = L["ErrorMailboxFailed"];
        }
        finally
        {
            _isLoading = false;
        }
    }

    public void Dispose() => ToolbarState.RemoveActions(_toolbarActions);

    private async Task<bool> HandleSaveAsync()
    {
        if (_isSaving || _model is null) return false;
        _isSaving = true;
        _errorMessage = null;
        _successMessage = null;

        try
        {
            var request = new UpdateMailboxRequest(
                _model.Name!, _model.EmailAddress!, _model.DisplayName,
                _model.ImapHost!, _model.ImapPort, _model.ImapUsername!, _model.ImapPassword,
                _model.ImapUseTls,
                _model.SmtpHost!, _model.SmtpPort, _model.SmtpUsername!, _model.SmtpPassword,
                _model.SmtpUseTls, _model.SmtpRequiresAuth);

            var response = await Http.PutAsJsonAsync($"/api/settings/mailboxes/{Id}", request);

            if (response.IsSuccessStatusCode)
            {
                _model.ImapPassword = null;
                _model.SmtpPassword = null;
                _successMessage = L["SuccessMailboxUpdated"];
                Notifications.Add(L["SuccessMailboxUpdated"], NotificationSeverity.Success);
                return true;
            }

            var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
            _errorMessage = error?.Message ?? L["ErrorMailboxFailed"];
        }
        catch
        {
            _errorMessage = L["ErrorMailboxFailed"];
        }
        finally
        {
            _isSaving = false;
        }

        return false;
    }

    private async Task HandleDeleteAsync()
    {
        _isDeleting = true;
        try
        {
            var response = await Http.DeleteAsync($"/api/settings/mailboxes/{Id}");

            if (response.IsSuccessStatusCode)
            {
                Navigation.NavigateTo("/settings/mailboxes");
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                _errorMessage = error?.Message ?? L["ErrorMailboxFailed"];
                _showDeleteModal = false;
            }
        }
        catch
        {
            _errorMessage = L["ErrorMailboxFailed"];
            _showDeleteModal = false;
        }
        finally
        {
            _isDeleting = false;
        }
    }

    private async Task TestImapAsync()
    {
        _isTestingImap = true;
        _imapTestResult = null;
        try
        {
            var request = new TestImapRequest(
                _model?.ImapHost ?? "", _model?.ImapPort ?? 993, _model?.ImapUsername, _model?.ImapPassword, _model?.ImapUseTls ?? true);
            var response = await Http.PostAsJsonAsync("/api/mail/test/imap", request);
            _imapTestResult = await response.Content.ReadFromJsonAsync<TestConnectionResponse>();
        }
        catch
        {
            _imapTestResult = new TestConnectionResponse(false, null, null);
        }
        finally
        {
            _isTestingImap = false;
        }
    }

    private async Task TestSmtpAsync()
    {
        _isTestingSmtp = true;
        _smtpTestResult = null;
        try
        {
            var request = new TestSmtpMailboxRequest(
                _model?.SmtpHost ?? "", _model?.SmtpPort ?? 587, _model?.SmtpUsername, _model?.SmtpPassword,
                _model?.SmtpUseTls ?? true, _model?.SmtpRequiresAuth ?? true);
            var response = await Http.PostAsJsonAsync("/api/mail/test/smtp", request);
            _smtpTestResult = await response.Content.ReadFromJsonAsync<TestConnectionResponse>();
        }
        catch
        {
            _smtpTestResult = new TestConnectionResponse(false, null, null);
        }
        finally
        {
            _isTestingSmtp = false;
        }
    }

    private string GetTestResultMessage(TestConnectionResponse result)
    {
        if (result.Success)
            return L["TestConnectionSuccess"];
        return result.ErrorStep switch
        {
            "dns" => L["TestConnectionFailedDns"],
            "tls" => L["TestConnectionFailedTls"],
            "auth" => L["TestConnectionFailedAuth"],
            _ => L["TestConnectionFailed"]
        };
    }

    private sealed class MailboxFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.StringLength(256)]
        public string? Name { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        [System.ComponentModel.DataAnnotations.StringLength(256)]
        public string? EmailAddress { get; set; }

        [System.ComponentModel.DataAnnotations.StringLength(256)]
        public string? DisplayName { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.StringLength(256)]
        public string? ImapHost { get; set; }

        [System.ComponentModel.DataAnnotations.Range(1, 65535)]
        public int ImapPort { get; set; } = 993;

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.StringLength(256)]
        public string? ImapUsername { get; set; }

        public string? ImapPassword { get; set; }

        public bool ImapUseTls { get; set; } = true;

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.StringLength(256)]
        public string? SmtpHost { get; set; }

        [System.ComponentModel.DataAnnotations.Range(1, 65535)]
        public int SmtpPort { get; set; } = 587;

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.StringLength(256)]
        public string? SmtpUsername { get; set; }

        public string? SmtpPassword { get; set; }

        public bool SmtpUseTls { get; set; } = true;

        public bool SmtpRequiresAuth { get; set; } = true;
    }

    private sealed record ErrorResponse(string Message);
}
