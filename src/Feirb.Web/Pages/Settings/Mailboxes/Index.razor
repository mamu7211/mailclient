@page "/settings/mailboxes"
@attribute [Authorize]
@using Feirb.Shared.Settings
@inject HttpClient Http
@inject IStringLocalizer<SharedResources> L
@inject NavigationManager Navigation
@inject ToolbarStateService ToolbarState
@implements IDisposable

<PageTitle>@L["PageTitleMailboxes"]</PageTitle>

<InfoHeader Title="@L["MailboxesHeading"]" Icon="envelope" Subtitle="@L["PageSubtitleMailboxes"]">
    <HelpContent>@L["PageHelpMailboxes"]</HelpContent>
</InfoHeader>

@if (_isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">@L["LoadingMailboxes"]</span>
        </div>
        <p class="mt-2 text-muted">@L["LoadingMailboxes"]</p>
    </div>
}
else if (_mailboxes is null || _mailboxes.Count == 0)
{
    <p class="text-muted">@L["NoMailboxesFound"]</p>
}
else
{
    <div class="d-flex flex-column gap-3">
        @foreach (var mailbox in _mailboxes)
        {
            <NavigationItem
                Icon="envelope"
                Title="@mailbox.Name"
                Subtitle="@mailbox.EmailAddress"
                Href="@($"/settings/mailboxes/{mailbox.Id}")" />
        }
    </div>
}

@code {
    private List<MailboxListResponse>? _mailboxes;
    private bool _isLoading = true;
    private ToolbarAction[] _toolbarActions = [];

    protected override async Task OnInitializedAsync()
    {
        _toolbarActions =
        [
            new ToolbarAction(L["ButtonAddMailbox"], ButtonVariant.Primary, () => { Navigation.NavigateTo("/settings/mailboxes/new"); return Task.CompletedTask; }, "plus-lg")
        ];
        ToolbarState.AddActions(_toolbarActions);

        try
        {
            _mailboxes = await Http.GetFromJsonAsync<List<MailboxListResponse>>("/api/settings/mailboxes");
        }
        catch
        {
            // Error handled by empty state
        }
        finally
        {
            _isLoading = false;
        }
    }

    public void Dispose() => ToolbarState.RemoveActions(_toolbarActions);
}
