@page "/settings/security"
@attribute [Authorize]
@using Feirb.Shared.Auth
@using Feirb.Shared.Settings
@inject HttpClient Http
@inject IStringLocalizer<SharedResources> L
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager Navigation

<PageTitle>@L["PageTitleSecurity"]</PageTitle>

@if (!string.IsNullOrEmpty(_successMessage))
{
    <div class="alert alert-success alert-dismissible py-2" role="alert">
        @_successMessage
        <button type="button" class="btn-close" @onclick="() => _successMessage = null"></button>
    </div>
}

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger alert-dismissible py-2" role="alert">
        @_errorMessage
        <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
    </div>
}

@* Change Password Section *@
<h5 class="text-muted mb-3">@L["SecurityChangePasswordTitle"]</h5>
<div class="card mb-4">
    <div class="card-body">
        <EditForm Model="_passwordModel" OnValidSubmit="HandleChangePasswordAsync">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label for="currentPassword" class="form-label">@L["LabelCurrentPassword"]</label>
                <InputText id="currentPassword" class="form-control" type="password" @bind-Value="_passwordModel.CurrentPassword" />
                <ValidationMessage For="() => _passwordModel.CurrentPassword" />
            </div>
            <div class="mb-3">
                <label for="newPassword" class="form-label">@L["LabelNewPassword"]</label>
                <InputText id="newPassword" class="form-control" type="password" @bind-Value="_passwordModel.NewPassword"
                    placeholder="@L["PlaceholderNewPassword"]" />
                <ValidationMessage For="() => _passwordModel.NewPassword" />
            </div>
            <div class="mb-3">
                <label for="confirmNewPassword" class="form-label">@L["LabelConfirmNewPassword"]</label>
                <InputText id="confirmNewPassword" class="form-control" type="password" @bind-Value="_passwordModel.ConfirmNewPassword" />
                <ValidationMessage For="() => _passwordModel.ConfirmNewPassword" />
            </div>
            <button type="submit" class="btn btn-primary" disabled="@_isChangingPassword">
                @if (_isChangingPassword)
                {
                    <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                }
                @L["ButtonChangePassword"]
            </button>
        </EditForm>
    </div>
</div>

@* Sessions Section *@
<h5 class="text-muted mb-3">@L["SecuritySessionsTitle"]</h5>
<div class="card">
    <div class="card-body">
        <p class="mb-3">@L["SecuritySessionsDescription"]</p>
        <button type="button" class="btn btn-outline-danger" @onclick="HandleLogoutAllAsync" disabled="@_isLoggingOutAll">
            @if (_isLoggingOutAll)
            {
                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
            }
            @L["ButtonLogoutAllSessions"]
        </button>
    </div>
</div>

@code {
    private PasswordFormModel _passwordModel = new();
    private bool _isChangingPassword;
    private bool _isLoggingOutAll;
    private string? _successMessage;
    private string? _errorMessage;

    private async Task HandleChangePasswordAsync()
    {
        if (_isChangingPassword) return;

        if (_passwordModel.NewPassword != _passwordModel.ConfirmNewPassword)
        {
            _errorMessage = L["ErrorPasswordsDoNotMatch"];
            return;
        }

        _isChangingPassword = true;
        _errorMessage = null;
        _successMessage = null;

        try
        {
            var request = new ChangePasswordRequest(_passwordModel.CurrentPassword!, _passwordModel.NewPassword!);
            var response = await Http.PutAsJsonAsync("/api/settings/profile/password", request);

            if (response.IsSuccessStatusCode)
            {
                // Re-authenticate to get fresh tokens with the new security stamp
                var authState = await AuthStateProvider.GetAuthenticationStateAsync();
                var username = authState.User.Identity?.Name;
                var loginRequest = new LoginRequest(username!, _passwordModel.NewPassword!);
                var loginResponse = await Http.PostAsJsonAsync("/api/auth/login", loginRequest);

                if (loginResponse.IsSuccessStatusCode && AuthStateProvider is JwtAuthenticationStateProvider jwtProvider)
                {
                    var tokens = await loginResponse.Content.ReadFromJsonAsync<TokenResponse>();
                    if (tokens is not null)
                        await jwtProvider.LoginAsync(tokens);
                }

                _successMessage = L["SuccessPasswordChanged"];
                _passwordModel = new PasswordFormModel();
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<MessageResponse>();
                _errorMessage = error?.Message ?? L["ErrorPasswordChangeFailed"];
            }
        }
        catch
        {
            _errorMessage = L["ErrorPasswordChangeFailed"];
        }
        finally
        {
            _isChangingPassword = false;
        }
    }

    private async Task HandleLogoutAllAsync()
    {
        if (_isLoggingOutAll) return;
        _isLoggingOutAll = true;
        _errorMessage = null;
        _successMessage = null;

        try
        {
            var response = await Http.PostAsync("/api/settings/profile/logout-all", null);

            if (response.IsSuccessStatusCode)
            {
                if (AuthStateProvider is JwtAuthenticationStateProvider jwtProvider)
                {
                    await jwtProvider.LogoutAsync();
                    Navigation.NavigateTo("/login", forceLoad: true);
                    return;
                }
            }
            else
            {
                _errorMessage = L["ErrorLogoutAllFailed"];
            }
        }
        catch
        {
            _errorMessage = L["ErrorLogoutAllFailed"];
        }
        finally
        {
            _isLoggingOutAll = false;
        }
    }

    private sealed class PasswordFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string? CurrentPassword { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.StringLength(256, MinimumLength = 8)]
        public string? NewPassword { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        public string? ConfirmNewPassword { get; set; }
    }

}
