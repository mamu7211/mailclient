@page "/settings/personal-information"
@attribute [Authorize]
@using Feirb.Shared.Settings
@inject HttpClient Http
@inject IStringLocalizer<SharedResources> L
@inject ToolbarStateService ToolbarState
@implements IDisposable

<PageTitle>@L["PageTitlePersonalInformation"]</PageTitle>

@if (!string.IsNullOrEmpty(_successMessage))
{
    <div class="alert alert-success alert-dismissible py-2" role="alert">
        @_successMessage
        <button type="button" class="btn-close" @onclick="() => _successMessage = null"></button>
    </div>
}

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger alert-dismissible py-2" role="alert">
        @_errorMessage
        <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
    </div>
}

@if (_isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">@L["LoadingProfile"]</span>
        </div>
    </div>
}
else if (_model is not null)
{
    <EditForm EditContext="_editContext" OnValidSubmit="HandleSaveAsync">
        <DataAnnotationsValidator />

        <div class="d-flex justify-content-center mb-4">
            <div style="width: 96px; height: 96px; border: 2px dashed #dee2e6; border-radius: 50%; display: flex; align-items: center; justify-content: center;">
                <span class="material-symbols-outlined text-muted" style="font-size: 48px;">person</span>
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <div class="mb-3">
                    <label for="username" class="form-label">@L["LabelUsername"]</label>
                    <InputText id="username" class="form-control" @bind-Value="_model.Username" />
                    <ValidationMessage For="() => _model.Username" />
                </div>
                <div class="mb-0">
                    <label for="email" class="form-label">@L["LabelEmail"]</label>
                    <InputText id="email" class="form-control" type="email" @bind-Value="_model.Email" />
                    <ValidationMessage For="() => _model.Email" />
                </div>
            </div>
        </div>
    </EditForm>
}

@code {
    private EditContext? _editContext;
    private ProfileFormModel? _model;
    private bool _isLoading = true;
    private bool _isSaving;
    private string? _successMessage;
    private string? _errorMessage;

    protected override async Task OnInitializedAsync()
    {
        ToolbarState.SetActions(
        [
            new ToolbarAction(L["ButtonSave"], "btn-primary", HandleSaveAsync, "check")
        ]);

        try
        {
            var profile = await Http.GetFromJsonAsync<ProfileResponse>("/api/settings/profile");
            if (profile is not null)
            {
                _model = new ProfileFormModel
                {
                    Username = profile.Username,
                    Email = profile.Email,
                };
                _editContext = new EditContext(_model);
            }
        }
        catch
        {
            _errorMessage = L["ErrorProfileFailed"];
        }
        finally
        {
            _isLoading = false;
        }
    }

    public void Dispose() => ToolbarState.Clear();

    private async Task HandleSaveAsync()
    {
        if (_isSaving || _model is null || _editContext is null) return;
        if (!_editContext.Validate()) return;
        _isSaving = true;
        _errorMessage = null;
        _successMessage = null;

        try
        {
            var request = new UpdateProfileRequest(_model.Username, _model.Email);
            var response = await Http.PutAsJsonAsync("/api/settings/profile", request);

            if (response.IsSuccessStatusCode)
            {
                _successMessage = L["SuccessProfileUpdated"];
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<MessageResponse>();
                _errorMessage = error?.Message ?? L["ErrorProfileFailed"];
            }
        }
        catch
        {
            _errorMessage = L["ErrorProfileFailed"];
        }
        finally
        {
            _isSaving = false;
        }
    }

    private sealed class ProfileFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.StringLength(100, MinimumLength = 2)]
        public string? Username { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        [System.ComponentModel.DataAnnotations.StringLength(256)]
        public string? Email { get; set; }
    }

}
