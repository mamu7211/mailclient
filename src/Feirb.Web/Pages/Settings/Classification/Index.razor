@page "/settings/classification"
@attribute [Authorize]
@using Feirb.Shared.Settings
@inject HttpClient Http
@inject IStringLocalizer<SharedResources> L
@inject ToolbarStateService ToolbarState
@inject NotificationService Notifications
@implements IDisposable

<PageTitle>@L["PageTitleClassificationRules"]</PageTitle>

<InfoHeader Title="@L["ClassificationRulesHeading"]" Icon="robot" Subtitle="@L["ClassificationRulesSubtitle"]">
    <HelpContent>@L["PageHelpClassificationRules"]</HelpContent>
</InfoHeader>

@if (!string.IsNullOrEmpty(_errorMessage))
{
    <div class="alert alert-danger alert-dismissible py-2" role="alert">
        @_errorMessage
        <button type="button" class="btn-close" @onclick="() => _errorMessage = null"></button>
    </div>
}

@if (_isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border" role="status">
            <span class="visually-hidden">@L["LoadingRules"]</span>
        </div>
        <p class="mt-2 text-muted">@L["LoadingRules"]</p>
    </div>
}
else if (_rules is null || _rules.Count == 0)
{
    <p class="text-muted">@L["NoRulesFound"]</p>
}
else
{
    <div class="d-flex flex-column gap-3">
        @foreach (var rule in _rules)
        {
            <div class="rule-card">
                <div class="flex-grow-1 min-width-0">
                    <div class="rule-instruction">@rule.Instruction</div>
                </div>
                <div class="d-flex gap-2 flex-shrink-0">
                    <CircularButton AriaLabel="@L["ButtonEdit"]" Variant="ButtonVariant.Secondary" Size="ButtonSize.Small" OnClick="() => OpenEditModal(rule)">
                        <Icon Name="pencil" Size="IconSize.Small" />
                    </CircularButton>
                    <CircularButton AriaLabel="@L["ButtonDelete"]" Variant="ButtonVariant.Danger" Size="ButtonSize.Small" OnClick="() => OpenDeleteModal(rule)">
                        <Icon Name="x-lg" Size="IconSize.Small" />
                    </CircularButton>
                </div>
            </div>
        }
    </div>
}

@* Create / Edit Modal *@
@if (_showEditModal)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@(_editingRule is null ? L["CreateRuleTitle"] : L["EditRuleTitle"])</h5>
                    <button type="button" class="btn-close" @onclick="CloseEditModal"></button>
                </div>
                <EditForm Model="_formModel" OnValidSubmit="HandleSaveAsync">
                    <DataAnnotationsValidator />
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="ruleInstruction" class="form-label">@L["RuleInstructionField"]</label>
                            <InputTextArea id="ruleInstruction" class="form-control" rows="4" @bind-Value="_formModel.Instruction" placeholder="@L["PlaceholderRuleInstruction"]" />
                            <ValidationMessage For="() => _formModel.Instruction" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <Button Variant="ButtonVariant.Secondary" OnClick="CloseEditModal">@L["ButtonCancel"]</Button>
                        <Button Variant="ButtonVariant.Primary" Type="submit" Disabled="_isSaving">
                            @if (_isSaving)
                            {
                                <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                            }
                            @L["ButtonSave"]
                        </Button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@* Delete Confirmation Modal *@
@if (_showDeleteModal && _deletingRule is not null)
{
    <div class="modal show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">@L["ConfirmDeleteRuleTitle"]</h5>
                    <button type="button" class="btn-close" @onclick="() => _showDeleteModal = false"></button>
                </div>
                <div class="modal-body">
                    <p>@L["ConfirmDeleteRuleMessage"]</p>
                </div>
                <div class="modal-footer">
                    <Button Variant="ButtonVariant.Secondary" OnClick="() => _showDeleteModal = false">@L["ButtonCancel"]</Button>
                    <Button Variant="ButtonVariant.Danger" OnClick="HandleDeleteAsync" Disabled="_isDeleting">
                        @if (_isDeleting)
                        {
                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        }
                        @L["ButtonConfirm"]
                    </Button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private List<ClassificationRuleResponse>? _rules;
    private bool _isLoading = true;
    private bool _isSaving;
    private bool _isDeleting;
    private string? _errorMessage;

    private bool _showEditModal;
    private bool _showDeleteModal;
    private ClassificationRuleResponse? _editingRule;
    private ClassificationRuleResponse? _deletingRule;
    private RuleFormModel _formModel = new();

    private ToolbarAction[] _toolbarActions = [];

    protected override void OnInitialized()
    {
        _toolbarActions =
        [
            new ToolbarAction(L["ButtonCreateRule"], ButtonVariant.Primary, () => { OpenCreateModal(); return Task.CompletedTask; }, "plus-lg")
        ];
        ToolbarState.AddActions(_toolbarActions);
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadRulesAsync();
    }

    public void Dispose() => ToolbarState.RemoveActions(_toolbarActions);

    private async Task LoadRulesAsync()
    {
        try
        {
            _rules = await Http.GetFromJsonAsync<List<ClassificationRuleResponse>>("/api/settings/rules");
        }
        catch
        {
            _errorMessage = L["ErrorRuleFailed"];
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void OpenCreateModal()
    {
        _editingRule = null;
        _formModel = new RuleFormModel();
        _showEditModal = true;
        StateHasChanged();
    }

    private void OpenEditModal(ClassificationRuleResponse rule)
    {
        _editingRule = rule;
        _formModel = new RuleFormModel { Instruction = rule.Instruction };
        _showEditModal = true;
    }

    private void CloseEditModal()
    {
        _showEditModal = false;
        _editingRule = null;
    }

    private void OpenDeleteModal(ClassificationRuleResponse rule)
    {
        _deletingRule = rule;
        _showDeleteModal = true;
    }

    private async Task HandleSaveAsync()
    {
        if (_isSaving) return;
        _isSaving = true;
        _errorMessage = null;

        try
        {
            HttpResponseMessage response;

            if (_editingRule is null)
            {
                var request = new CreateClassificationRuleRequest(_formModel.Instruction!);
                response = await Http.PostAsJsonAsync("/api/settings/rules", request);
            }
            else
            {
                var request = new UpdateClassificationRuleRequest(_formModel.Instruction!);
                response = await Http.PutAsJsonAsync($"/api/settings/rules/{_editingRule.Id}", request);
            }

            if (response.IsSuccessStatusCode)
            {
                var message = _editingRule is null ? L["SuccessRuleCreated"] : L["SuccessRuleUpdated"];
                Notifications.Add(message, NotificationSeverity.Success);
                CloseEditModal();
                _isLoading = true;
                await LoadRulesAsync();
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                _errorMessage = error?.Message ?? L["ErrorRuleFailed"];
            }
        }
        catch
        {
            _errorMessage = L["ErrorRuleFailed"];
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task HandleDeleteAsync()
    {
        if (_isDeleting || _deletingRule is null) return;
        _isDeleting = true;

        try
        {
            var response = await Http.DeleteAsync($"/api/settings/rules/{_deletingRule.Id}");

            if (response.IsSuccessStatusCode)
            {
                Notifications.Add(L["SuccessRuleDeleted"], NotificationSeverity.Success);
                _showDeleteModal = false;
                _deletingRule = null;
                _isLoading = true;
                await LoadRulesAsync();
            }
            else
            {
                var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                _errorMessage = error?.Message ?? L["ErrorRuleFailed"];
                _showDeleteModal = false;
            }
        }
        catch
        {
            _errorMessage = L["ErrorRuleFailed"];
            _showDeleteModal = false;
        }
        finally
        {
            _isDeleting = false;
        }
    }

    private sealed class RuleFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.StringLength(500)]
        public string? Instruction { get; set; }
    }

    private sealed record ErrorResponse(string Message);
}
