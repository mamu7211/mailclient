@page "/compose"
@attribute [Authorize]
@using Feirb.Shared.Mail
@using Feirb.Shared.Settings
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IJSRuntime Js
@inject IStringLocalizer<SharedResources> L
@inject NotificationService Notifications
@inject ToolbarStateService ToolbarState
@implements IDisposable

<PageTitle>@L["ComposePageTitle"]</PageTitle>

@if (_isLoading)
{
    <div class="text-center py-5">
        <div class="spinner-border" role="status"></div>
    </div>
}
else if (_mailboxes is null || _mailboxes.Count == 0)
{
    <div class="alert alert-warning" data-testid="compose-no-mailboxes">
        @L["ComposeNoMailboxes"]
    </div>
}
else
{
    <div data-testid="compose-form">
        <ContentSection Icon="people" Title="@L["ComposeCorrespondentsHeading"]">
            @* Sender *@
            <div class="mb-3" data-testid="compose-from-single">
                @if (_mailboxes.Count == 1)
                {
                    <PersonChip Name="@_mailboxes[0].Name" Email="@_mailboxes[0].EmailAddress" />
                }
                else
                {
                    <select id="mailbox" class="form-select" @bind="_selectedMailboxId" data-testid="compose-from-select">
                        @foreach (var mb in _mailboxes)
                        {
                            <option value="@mb.Id">@mb.Name (@mb.EmailAddress)</option>
                        }
                    </select>
                }
            </div>

            @* To + CC/BCC toggle *@
            <div class="mb-3">
                <label class="form-label fw-semibold" for="to">@L["ComposeTo"]</label>
                <div class="d-flex align-items-center gap-2">
                    <input id="to" type="text" class="form-control @(HasError("to") ? "is-invalid" : "")"
                           @bind="_to" placeholder="@L["ComposePlaceholderTo"]" data-testid="compose-to" />
                    <Toggle Text="@L["ComposeShowCcBcc"]"
                            DisabledText="@L["ComposeShowCcBccOff"]"
                            @bind-Value="_showCcBcc"
                            Class="flex-shrink-0"
                            data-testid="compose-show-cc-bcc" />
                </div>
                @if (HasError("to"))
                {
                    <div class="invalid-feedback d-block">@GetError("to")</div>
                }
            </div>

            @if (_showCcBcc)
            {
                <div class="mb-3">
                    <label class="form-label fw-semibold" for="cc">@L["ComposeCc"]</label>
                    <input id="cc" type="text" class="form-control @(HasError("cc") ? "is-invalid" : "")"
                           @bind="_cc" placeholder="@L["ComposePlaceholderCc"]" data-testid="compose-cc" />
                    @if (HasError("cc"))
                    {
                        <div class="invalid-feedback">@GetError("cc")</div>
                    }
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold" for="bcc">@L["ComposeBcc"]</label>
                    <input id="bcc" type="text" class="form-control @(HasError("bcc") ? "is-invalid" : "")"
                           @bind="_bcc" placeholder="@L["ComposePlaceholderBcc"]" data-testid="compose-bcc" />
                    @if (HasError("bcc"))
                    {
                        <div class="invalid-feedback">@GetError("bcc")</div>
                    }
                </div>
            }
        </ContentSection>

        <ContentSection Icon="pencil" Title="@L["ComposeMessageHeading"]" Class="mt-3">
            @* Subject *@
            <div class="mb-3">
                <label class="form-label fw-semibold" for="subject">@L["ComposeSubject"]</label>
                <input id="subject" type="text" class="form-control @(HasError("subject") ? "is-invalid" : "")"
                       @bind="_subject" placeholder="@L["ComposePlaceholderSubject"]" data-testid="compose-subject" />
                @if (HasError("subject"))
                {
                    <div class="invalid-feedback">@GetError("subject")</div>
                }
            </div>

            @* Editor mode toggle *@
            <div class="mb-2 d-flex align-items-center gap-2">
                <label class="form-label fw-semibold mb-0">@L["ComposeBody"]</label>
                <ToggleButtonGroup Items="_editorModeItems"
                                   SelectedId="@_editorMode.ToString()"
                                   SelectedIdChanged="OnEditorModeChangedAsync"
                                   Class="ms-auto" />
            </div>

            @* Rich text editor (Quill) *@
            <div style="@(_editorMode == EditorMode.RichText ? "" : "display:none")">
                <div @ref="_quillEditorRef" data-testid="compose-editor-rich"
                     style="min-height: 300px; display: flex; flex-direction: column;"></div>
            </div>

            <style>
                [data-testid="compose-form"] ::selection {
                    background-color: var(--bs-primary);
                    color: white;
                }
                .ql-toolbar {
                    border-color: var(--bs-border-color) !important;
                    border-radius: var(--bs-border-radius) var(--bs-border-radius) 0 0;
                }
                .ql-container {
                    flex: 1;
                    min-height: 250px;
                    border-color: var(--bs-border-color) !important;
                    border-radius: 0 0 var(--bs-border-radius) var(--bs-border-radius);
                }
                .ql-editor { min-height: 250px; }
                .ql-snow .ql-stroke { stroke: var(--bs-body-color) !important; }
                .ql-snow .ql-fill, .ql-snow .ql-stroke.ql-fill { fill: var(--bs-body-color) !important; }
                .ql-snow .ql-picker { color: var(--bs-body-color) !important; }
                .ql-snow .ql-picker-label {
                    border-color: var(--bs-border-color) !important;
                    border-radius: var(--bs-border-radius) !important;
                }
                .ql-snow .ql-picker.ql-expanded .ql-picker-label {
                    border-radius: var(--bs-border-radius) var(--bs-border-radius) 0 0 !important;
                    border-bottom-color: var(--bs-border-color) !important;
                }
                .ql-snow .ql-picker-label.ql-active,
                .ql-snow .ql-picker-label:hover,
                .ql-snow .ql-picker-item.ql-selected,
                .ql-snow .ql-picker-item:hover {
                    color: var(--bs-primary) !important;
                }
                .ql-snow .ql-picker-options {
                    background-color: var(--feirb-surface) !important;
                    border-color: var(--bs-border-color) !important;
                    border-radius: 0 var(--bs-border-radius) var(--bs-border-radius) var(--bs-border-radius) !important;
                    min-width: 100%;
                }
            </style>

            @* Markdown editor *@
            <div style="@(_editorMode == EditorMode.Markdown ? "" : "display:none")">
                <textarea class="form-control font-monospace @(HasError("body") ? "is-invalid" : "")"
                          rows="12" @bind="_markdownBody" data-testid="compose-editor-markdown"></textarea>
                <Toggle Text="@L["ComposeSendFormattedOn"]"
                        DisabledText="@L["ComposeSendFormattedOff"]"
                        @bind-Value="_sendFormatted"
                        Class="mt-2"
                        data-testid="compose-send-formatted" />
            </div>

            @if (HasError("body"))
            {
                <div class="text-danger small mt-1">@GetError("body")</div>
            }
        </ContentSection>
    </div>
}

@code {
    private List<MailboxListResponse>? _mailboxes;
    private Guid _selectedMailboxId;
    private bool _isLoading = true;
    private bool _isSending;
    private bool _showCcBcc;

    private string _to = "";
    private string _cc = "";
    private string _bcc = "";
    private string _subject = "";
    private string _markdownBody = "";
    private bool _sendFormatted = true;

    private EditorMode _editorMode = EditorMode.RichText;
    private ElementReference _quillEditorRef;
    private bool _quillInitialized;

    private Dictionary<string, string> _errors = [];

    private ToggleButtonItem[] _editorModeItems = [];

    private ToolbarAction[] _toolbarActions = [];

    protected override async Task OnInitializedAsync()
    {
        _editorModeItems =
        [
            new(nameof(EditorMode.RichText), L["ComposeModeRichText"]),
            new(nameof(EditorMode.Markdown), L["ComposeModeMarkdown"])
        ];

        try
        {
            _mailboxes = await Http.GetFromJsonAsync<List<MailboxListResponse>>("/api/settings/mailboxes");
            if (_mailboxes is { Count: > 0 })
                _selectedMailboxId = _mailboxes[0].Id;
        }
        catch
        {
            Notifications.Add(L["ComposeLoadMailboxesFailed"], NotificationSeverity.Error);
        }
        finally
        {
            _isLoading = false;
        }

        _toolbarActions =
        [
            new ToolbarAction(L["ComposeButtonSend"], ButtonVariant.Primary, SendAsync, "send-fill")
        ];
        ToolbarState.AddActions(_toolbarActions);
    }

    public void Dispose() => ToolbarState.RemoveActions(_toolbarActions);

    private async Task OnEditorModeChangedAsync(string id)
    {
        if (id == nameof(EditorMode.RichText))
            await SwitchToRichTextAsync();
        else
            await SwitchToMarkdownAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_quillInitialized && _mailboxes is { Count: > 0 } && _editorMode == EditorMode.RichText)
        {
            await Js.InvokeVoidAsync("quillInterop.init", _quillEditorRef);
            _quillInitialized = true;
        }
    }

    private async Task SwitchToRichTextAsync()
    {
        if (_editorMode == EditorMode.RichText) return;

        // Convert markdown to HTML and load into Quill
        var html = await Js.InvokeAsync<string>("markedInterop.toHtml", _markdownBody);
        _editorMode = EditorMode.RichText;
        StateHasChanged();
        await Task.Delay(50); // Wait for Quill container to be visible
        if (!_quillInitialized)
        {
            await Js.InvokeVoidAsync("quillInterop.init", _quillEditorRef);
            _quillInitialized = true;
        }
        await Js.InvokeVoidAsync("quillInterop.setHtml", html);
    }

    private async Task SwitchToMarkdownAsync()
    {
        if (_editorMode == EditorMode.Markdown) return;

        // Convert HTML from Quill to Markdown via Turndown
        var html = await Js.InvokeAsync<string>("quillInterop.getHtml");
        _markdownBody = await Js.InvokeAsync<string>("markedInterop.toMarkdown", html);
        _editorMode = EditorMode.Markdown;
    }

    private async Task SendAsync()
    {
        if (_isSending) return;

        _errors.Clear();
        var (body, contentType) = await GetBodyAndContentTypeAsync();

        // Validate
        var toAddresses = ParseEmails(_to);
        var ccAddresses = ParseEmails(_cc);
        var bccAddresses = ParseEmails(_bcc);

        if (toAddresses.Length == 0)
            _errors["to"] = L["ComposeValidationTo"];

        foreach (var email in toAddresses.Concat(ccAddresses).Concat(bccAddresses))
        {
            if (!IsValidEmail(email))
            {
                var field = toAddresses.Contains(email) ? "to" : ccAddresses.Contains(email) ? "cc" : "bcc";
                _errors.TryAdd(field, string.Format(L["ComposeValidationEmail"], email));
            }
        }

        if (string.IsNullOrWhiteSpace(_subject))
            _errors["subject"] = L["ComposeValidationSubject"];

        if (string.IsNullOrWhiteSpace(body))
            _errors["body"] = L["ComposeValidationBody"];

        if (_errors.Count > 0)
        {
            StateHasChanged();
            return;
        }

        _isSending = true;

        try
        {
            var request = new SendMailRequest(
                _selectedMailboxId,
                toAddresses,
                ccAddresses.Length > 0 ? ccAddresses : null,
                bccAddresses.Length > 0 ? bccAddresses : null,
                _subject,
                body!,
                contentType);

            var response = await Http.PostAsJsonAsync("/api/mail/send", request);

            if (response.IsSuccessStatusCode)
            {
                Notifications.Add(L["ComposeSendSuccess"], NotificationSeverity.Success);
                Navigation.NavigateTo("/mail/inbox");
                return;
            }

            var error = await response.Content.ReadAsStringAsync();
            Notifications.Add(L["ComposeSendFailed"], NotificationSeverity.Error);
        }
        catch
        {
            Notifications.Add(L["ComposeSendFailed"], NotificationSeverity.Error);
        }
        finally
        {
            _isSending = false;
        }
    }

    private async Task<(string? Body, string ContentType)> GetBodyAndContentTypeAsync()
    {
        if (_editorMode == EditorMode.RichText)
        {
            var isEmpty = await Js.InvokeAsync<bool>("quillInterop.isEmpty");
            if (isEmpty) return (null, "html");
            var html = await Js.InvokeAsync<string>("quillInterop.getHtml");
            return (html, "html");
        }

        // Markdown mode
        if (string.IsNullOrWhiteSpace(_markdownBody))
            return (null, "plain");

        if (_sendFormatted)
        {
            var html = await Js.InvokeAsync<string>("markedInterop.toHtml", _markdownBody);
            return (html, "html");
        }

        return (_markdownBody, "plain");
    }

    private static string[] ParseEmails(string input) =>
        string.IsNullOrWhiteSpace(input)
            ? []
            : input.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
                   .Where(e => !string.IsNullOrWhiteSpace(e))
                   .ToArray();

    private static bool IsValidEmail(string email)
    {
        try
        {
            var addr = new System.Net.Mail.MailAddress(email);
            return addr.Address == email;
        }
        catch
        {
            return false;
        }
    }

    private bool HasError(string field) => _errors.ContainsKey(field);
    private string GetError(string field) => _errors.GetValueOrDefault(field, "");

    private enum EditorMode { RichText, Markdown }
}
