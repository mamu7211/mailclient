@page "/register"
@using Feirb.Shared.Auth
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["PageTitleRegister"]</PageTitle>

<div class="d-flex align-items-center justify-content-center position-relative" style="min-height: 100vh;">
    <div class="position-absolute top-0 end-0 p-3">
        <Feirb.Web.Components.LanguageSwitcher ButtonClass="btn-outline-secondary" />
    </div>
    <div class="card p-4 p-md-5" style="width: 100%; max-width: 440px;">
        <h2 class="mb-1 text-center fw-bold">@L["RegisterHeading"]</h2>
        <p class="text-center text-muted mb-4">@L["RegisterSubheading"]</p>

        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="alert alert-danger py-2" role="alert">@_errorMessage</div>
        }

        <EditForm Model="_model" OnValidSubmit="HandleRegisterAsync" FormName="register">
            <DataAnnotationsValidator />

            <div class="mb-3">
                <label for="username" class="form-label small fw-medium">@L["LabelUsername"]</label>
                <InputText id="username" class="form-control form-control-lg" placeholder="@L["PlaceholderUsername"]" @bind-Value="_model.Username" />
                <ValidationMessage For="() => _model.Username" />
            </div>

            <div class="mb-3">
                <label for="email" class="form-label small fw-medium">@L["LabelEmail"]</label>
                <InputText id="email" class="form-control form-control-lg" type="email" placeholder="@L["PlaceholderEmail"]" @bind-Value="_model.Email" />
                <ValidationMessage For="() => _model.Email" />
            </div>

            <div class="mb-3">
                <label for="password" class="form-label small fw-medium">@L["LabelPassword"]</label>
                <InputText id="password" class="form-control form-control-lg" type="password" placeholder="@L["PlaceholderPassword"]" @bind-Value="_model.Password" />
                <ValidationMessage For="() => _model.Password" />
            </div>

            <div class="mb-4">
                <label for="confirmPassword" class="form-label small fw-medium">@L["LabelConfirmPassword"]</label>
                <InputText id="confirmPassword" class="form-control form-control-lg" type="password" placeholder="@L["PlaceholderConfirmPassword"]" @bind-Value="_model.ConfirmPassword" />
                @if (_model.ConfirmPassword is not null && _model.Password != _model.ConfirmPassword)
                {
                    <div class="validation-message">@L["ErrorPasswordsDoNotMatch"]</div>
                }
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100" disabled="@_isSubmitting">
                @if (_isSubmitting)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                }
                @L["ButtonCreateAccount"]
            </button>
        </EditForm>

        <p class="mt-4 text-center text-muted mb-0">
            @L["AlreadyHaveAccount"] <a href="/login">@L["LinkLogIn"]</a>
        </p>
    </div>
</div>

@code {
    private readonly RegisterFormModel _model = new();
    private string? _errorMessage;
    private bool _isSubmitting;

    private async Task HandleRegisterAsync()
    {
        if (_model.Password != _model.ConfirmPassword)
        {
            _errorMessage = L["ErrorPasswordsDoNotMatch"];
            return;
        }

        _isSubmitting = true;
        _errorMessage = null;

        var request = new RegisterRequest(_model.Username!, _model.Email!, _model.Password!);
        var response = await Http.PostAsJsonAsync("/api/auth/register", request);

        if (response.IsSuccessStatusCode)
        {
            Navigation.NavigateTo("/login?registered=true");
        }
        else if (response.StatusCode == System.Net.HttpStatusCode.Conflict)
        {
            var error = await response.Content.ReadFromJsonAsync<ErrorResponse>();
            _errorMessage = error?.Message ?? L["ErrorUsernameOrEmailTaken"];
        }
        else
        {
            _errorMessage = L["ErrorRegistrationFailed"];
        }

        _isSubmitting = false;
    }

    private sealed class RegisterFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.StringLength(100, MinimumLength = 3)]
        public string? Username { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string? Email { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.MinLength(8)]
        public string? Password { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        public string? ConfirmPassword { get; set; }
    }

    private sealed record ErrorResponse(string Message);
}
