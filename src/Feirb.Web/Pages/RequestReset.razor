@page "/reset-password"
@layout AuthLayout
@attribute [AllowAnonymous]
@using Feirb.Shared.Auth
@inject HttpClient Http
@inject IStringLocalizer<SharedResources> L

<PageTitle>@L["PageTitleRequestReset"]</PageTitle>

<div class="position-relative w-100">
    <div class="position-absolute top-0 end-0 p-3">
        <Feirb.Web.Components.LanguageSwitcher ButtonClass="btn-outline-secondary" />
    </div>
    <div class="d-flex align-items-center justify-content-center" style="min-height: 100vh;">
        <div class="card p-4 p-md-5" style="width: 100%; max-width: 440px;">
            <div class="text-center mb-4">
                <h1 class="fw-bold fs-2 text-primary mb-0">@L["AppName"]</h1>
            </div>
            <h2 class="mb-1 text-center fw-bold">@L["RequestResetHeading"]</h2>
            <p class="text-center text-muted mb-4">@L["RequestResetSubheading"]</p>

            @if (_submitted)
            {
                <div class="alert alert-success py-2" role="alert">@L["ResetRequestSentMessage"]</div>
            }
            else
            {
                <EditForm Model="_model" OnValidSubmit="HandleSubmitAsync" FormName="requestReset">
                    <DataAnnotationsValidator />

                    <div class="mb-4">
                        <label for="email" class="form-label small fw-medium">@L["LabelEmail"]</label>
                        <InputText id="email" class="form-control form-control-lg" type="email" placeholder="@L["PlaceholderEmail"]" @bind-Value="_model.Email" />
                        <ValidationMessage For="() => _model.Email" />
                    </div>

                    <Button Variant="ButtonVariant.Primary" Size="ButtonSize.Large" Type="submit" Disabled="_isSubmitting" Class="w-100">
                        @if (_isSubmitting)
                        {
                            <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                        }
                        @L["ButtonSendResetLink"]
                    </Button>
                </EditForm>
            }

            <div class="mt-3 text-center">
                <a href="/login" class="text-muted small">@L["BackToLogin"]</a>
            </div>
        </div>
    </div>
</div>

@code {
    private readonly RequestResetFormModel _model = new();
    private bool _isSubmitting;
    private bool _submitted;

    private async Task HandleSubmitAsync()
    {
        _isSubmitting = true;

        var request = new RequestResetRequest(_model.Email!);
        await Http.PostAsJsonAsync("/api/auth/request-reset", request);

        _submitted = true;
        _isSubmitting = false;
    }

    private sealed class RequestResetFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        [System.ComponentModel.DataAnnotations.EmailAddress]
        public string? Email { get; set; }
    }
}
