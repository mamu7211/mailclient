@page "/components-showcase"
@page "/components-showcase/{Section}"
@attribute [AllowAnonymous]
@layout Feirb.Web.Layout.ShowcaseLayout

@using Feirb.Web.Pages.Showcase

@switch (Section)
{
    case null:
    case "":
        <ShowcaseDesignFundamentals />
        break;
    case "icon":
        <ShowcaseIcon />
        break;
    case "heading":
        <ShowcaseHeading />
        break;
    case "button":
        <ShowcaseButton />
        break;
    case "circular-button":
        <ShowcaseCircularButton />
        break;
    case "dropdown-button":
        <ShowcaseDropdownButton />
        break;
    case "card":
        <ShowcaseCard />
        break;
    case "navigation-item":
        <ShowcaseNavigationItem />
        break;
    case "content-section":
        <ShowcaseContentSection />
        break;
    case "info-header":
        <ShowcaseInfoHeader />
        break;
    case "sidebar-menu":
        <ShowcaseSidebarMenu />
        break;
    case "toggle-button-group":
        <ShowcaseToggleButtonGroup />
        break;
    case "toggle":
        <ShowcaseToggle />
        break;
    case "toast":
        <ShowcaseToast />
        break;
    case "label-pill":
        <ShowcaseLabelPill />
        break;
    case "mail-card":
        <ShowcaseMailCard />
        break;
    case "table":
        <ShowcaseTable />
        break;
    case "pagination":
        <ShowcasePagination />
        break;
    case "person-chip":
        <ShowcasePersonChip />
        break;
    case "datetime-chip":
        <ShowcaseDateTimeChip />
        break;
    case "mail-subject-chip":
        <ShowcaseMailSubjectChip />
        break;
    case "mailbox-chip":
        <ShowcaseMailboxChip />
        break;
    case "job-chip":
        <ShowcaseJobChip />
        break;
    case "execution-history-chip":
        <ShowcaseExecutionHistoryChip />
        break;
    case "job-settings-panel":
        <ShowcaseJobSettingsPanel />
        break;
    case "status-message":
        <ShowcaseStatusMessage />
        break;
    case "status-banner":
        <ShowcaseStatusBanner />
        break;
    case "recipient-input":
        <ShowcaseRecipientInput />
        break;
    case "help-hint":
        <ShowcaseHelpHint />
        break;
    default:
        <div class="text-center py-5">
            <Feirb.Web.Components.UI.Icon Name="palette2" Size="Feirb.Web.Components.UI.IconSize.Large" Class="mb-3 d-block mx-auto" />
            <p class="text-muted">Component not found.</p>
        </div>
        break;
}

@code {
    [Parameter]
    public string? Section { get; set; }
}
