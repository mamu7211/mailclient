@page "/login"
@layout AuthLayout
@attribute [AllowAnonymous]
@using System.Text.Json
@using Feirb.Shared.Auth
@using Feirb.Web.Services
@inject HttpClient Http
@inject NavigationManager Navigation
@inject JwtAuthenticationStateProvider AuthStateProvider
@inject IStringLocalizer<SharedResources> L
@using Microsoft.AspNetCore.Components.WebAssembly.Hosting
@inject IWebAssemblyHostEnvironment HostEnvironment

<PageTitle>@L["PageTitleLogin"]</PageTitle>

<div class="position-relative w-100">
    @if (HostEnvironment.IsDevelopment())
    {
        <a href="components-showcase" class="position-absolute top-0 start-0 p-3 text-muted" title="Component Showcase">
            <Feirb.Web.Components.UI.Icon Name="palette2" Size="Feirb.Web.Components.UI.IconSize.Large" />
        </a>
    }
    <div class="position-absolute top-0 end-0 p-3">
        <Feirb.Web.Components.LanguageSwitcher ButtonClass="btn-outline-secondary" />
    </div>
    <div class="d-flex align-items-center justify-content-center" style="min-height: 100vh;">
        <div class="card p-4 p-md-5" style="width: 100%; max-width: 440px;">
            <div class="text-center mb-4">
                <h1 class="fw-bold fs-2 text-primary mb-0">@L["AppName"]</h1>
            </div>
            <h2 class="mb-1 text-center fw-bold">@L["LoginHeading"]</h2>
            <p class="text-center text-muted mb-4">@L["LoginSubheading"]</p>

            @if (_showRegisteredMessage)
            {
                <div class="alert alert-success py-2" role="alert">@L["SuccessRegistered"]</div>
            }

            @if (_showResetMessage)
            {
                <div class="alert alert-success py-2" role="alert">@L["SuccessPasswordReset"]</div>
            }

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="alert alert-danger py-2" role="alert">@_errorMessage</div>
            }

            <EditForm Model="_model" OnValidSubmit="HandleLoginAsync" FormName="login">
                <DataAnnotationsValidator />

                <div class="mb-3">
                    <label for="username" class="form-label small fw-medium">@L["LabelUsername"]</label>
                    <InputText id="username" class="form-control form-control-lg" placeholder="@L["PlaceholderLoginUsername"]" @bind-Value="_model.Username" />
                    <ValidationMessage For="() => _model.Username" />
                </div>

                <div class="mb-4">
                    <label for="password" class="form-label small fw-medium">@L["LabelPassword"]</label>
                    <InputText id="password" class="form-control form-control-lg" type="password" placeholder="@L["PlaceholderLoginPassword"]" @bind-Value="_model.Password" />
                    <ValidationMessage For="() => _model.Password" />
                </div>

                <Button Variant="ButtonVariant.Primary" Size="ButtonSize.Large" Type="submit" Disabled="_isSubmitting" Class="w-100">
                    @if (_isSubmitting)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status"></span>
                    }
                    @L["ButtonLogIn"]
                </Button>
            </EditForm>

            <div class="mt-3 text-center">
                <a href="/reset-password" class="text-muted small">@L["ForgotPassword"]</a>
            </div>

            <p class="mt-4 text-center text-muted mb-0">
                @L["DontHaveAccount"] <a href="/register">@L["LinkCreateAccount"]</a>
            </p>
        </div>
    </div>
</div>

@code {
    private readonly LoginFormModel _model = new();
    private string? _errorMessage;
    private bool _isSubmitting;
    private bool _showRegisteredMessage;
    private bool _showResetMessage;

    protected override async Task OnInitializedAsync()
    {
        var uri = new Uri(Navigation.Uri);
        _showRegisteredMessage = uri.Query.Contains("registered=true");
        _showResetMessage = uri.Query.Contains("reset=true");

        if (HostEnvironment.IsDevelopment() && await IsAutoLoginEnabledAsync())
        {
            _model.Username = "admin";
            _model.Password = "admin@feirb.local";
            await HandleLoginAsync();
        }
    }

    private async Task HandleLoginAsync()
    {
        _isSubmitting = true;
        _errorMessage = null;
        _showRegisteredMessage = false;
        _showResetMessage = false;

        var request = new LoginRequest(_model.Username!, _model.Password!);
        var response = await Http.PostAsJsonAsync("/api/auth/login", request);

        if (response.IsSuccessStatusCode)
        {
            var tokens = await response.Content.ReadFromJsonAsync<TokenResponse>();
            if (tokens is not null)
            {
                await AuthStateProvider.LoginAsync(tokens);
                Navigation.NavigateTo("/");
                return;
            }
        }

        _errorMessage = response.StatusCode == System.Net.HttpStatusCode.Unauthorized
            ? L["ErrorInvalidCredentials"]
            : L["ErrorLoginFailed"];

        _isSubmitting = false;
    }

    private async Task<bool> IsAutoLoginEnabledAsync()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<JsonElement>("/api/dev/config");
            return response.TryGetProperty("autoLogin", out var val) && val.GetBoolean();
        }
        catch
        {
            return false;
        }
    }

    private sealed class LoginFormModel
    {
        [System.ComponentModel.DataAnnotations.Required]
        public string? Username { get; set; }

        [System.ComponentModel.DataAnnotations.Required]
        public string? Password { get; set; }
    }
}
